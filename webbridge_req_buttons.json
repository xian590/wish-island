{"action":"evaluate","args":{"code":"(()=>{try{var els=document.querySelectorAll('button, div[role=button], a, [onclick]');var out=[];for(var i=0;i<els.length;i++){var t=els[i].innerText||els[i].textContent||els[i].getAttribute('aria-label')||'';if(t.trim().length>0)out.push({tag:els[i].tagName,text:t.trim().substring(0,40)});}return{count:out.length,list:out.slice(0,30)};}catch(e){return{error:e.message};}})()"},"session":"farm-game"}
