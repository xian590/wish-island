{"action":"evaluate","args":{"code":"(()=>{try{const s=JSON.parse(localStorage.getItem('farm_game_save_v1'));const keys=Object.keys(s);return JSON.stringify({day:s.day,season:s.season,time:s.time,weather:s.weather,money:s.money,health:s.health,stamina:s.stamina,daysPlayed:s.daysPlayed,reputation:s.reputation,mood:s.mood,disasterRate:s.disasterRate,fieldCount:s.fields?s.fields.length:0,house:s.house,composting:s.composting,storageLimit:s.storageLimit,eventCount:s.events?s.events.length:0,milestoneCount:s.milestones?Object.keys(s.milestones).length:0,questCompleted:s.quests?Object.values(s.quests).filter(Boolean).length:0,version:s.version||'v1',skillTotal:s.skills?Object.values(s.skills).reduce((a,v)=>a+v.level,0):0,petCount:s.pets?Object.keys(s.pets).length:0,allKeys:keys});}catch(e){return JSON.stringify({error:e.message});}})()"},"session":"farm-game"}
