{"action":"evaluate","args":{"code":"(()=>{try{var ls=localStorage.getItem('farm_game_save_v1');if(!ls)return{error:'no save'};var s=JSON.parse(ls);return{day:s.day,season:s.season,weather:s.weather,money:s.money,energy:s.energy,maxEnergy:s.maxEnergy,health:s.health,maxHealth:s.maxHealth,fields:s.fields?s.fields.length:0,events:s.eventHistory?s.eventHistory.length:0,skills:s.skills?Object.keys(s.skills).map(function(k){return k+':'+s.skills[k].level;}).join(','):'none',npcs:s.npcs?Object.keys(s.npcs).map(function(k){return k+':'+s.npcs[k].affection;}).join('/'):'none',reputation:s.reputation,mood:s.mood,house:s.house?s.house.level:'none',mode:s.difficulty||s.mode,version:s.saveVersion,saveSize:ls.length,warehouse:s.warehouse?{rice:s.warehouse.rice||0,sweetPotato:s.warehouse.sweetPotato||0,limit:s.warehouse.limit||0}:null,processed:s.processedItems?Object.keys(s.processedItems).map(function(k){return k+':'+s.processedItems[k];}).join(','):'none',research:s.researchPoints||0,totalHarvest:s.statistics?s.statistics.totalHarvest:0,totalSales:s.statistics?s.statistics.totalSales:0,pets:Array.isArray(s.pets)?s.pets.map(function(p){return p.name;}).join(','):'none',milestones:Array.isArray(s.milestones)?s.milestones.filter(function(m){return m.unlocked;}).length+'/'+s.milestones.length:'none',quests:Array.isArray(s.quests)?s.quests.filter(function(q){return q.completed;}).length+'/'+s.quests.length:'none',daysPlayed:s.daysPlayed||s.day,disasterRate:s.disasterRate||'-',speed:s.speed||1,eventHistoryLast:Array.isArray(s.eventHistory)?s.eventHistory.slice(-3).map(function(e){return e.text;}):[]};}catch(e){return{error:e.message};}})()"},"session":"farm-game"}
