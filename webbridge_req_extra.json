{"action":"evaluate","args":{"code":"(()=>{try{const s=JSON.parse(localStorage.getItem('farm_game_save_v1'));return JSON.stringify({daysPlayed:s.daysPlayed,reputation:s.reputation,mood:s.mood,totalHarvest:s.totalHarvest,totalSales:s.totalSales,weather:s.weather,version:s.version||'v1',eventCount:s.events?s.events.length:0,milestoneCount:s.milestones?Object.keys(s.milestones).length:0,unlockedTabs:s.unlockedTabs?s.unlockedTabs.length:0,day:s.day});}catch(e){return JSON.stringify({error:e.message});}})()"},"session":"farm-game"}