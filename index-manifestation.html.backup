<!-- ========== 情绪趋势图表 ========== -->
<section id="page-mood-chart" class="page" style="padding-bottom:100px;">
  <div class="glass-header sticky top-0 z-40 px-5 py-4">
    <div class="flex items-center justify-between max-w-lg mx-auto">
      <button onclick="goHome()" class="soft-btn w-10 h-10 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,0.6)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="text-lg font-medium" style="color:var(--theme-text)">情绪趋势</h1>
      <div class="w-10"></div>
    </div>
  </div>
  <div class="max-w-lg mx-auto px-5 py-6">
    <div class="glass-card p-5 mb-6 text-center">
      <div class="text-3xl mb-2">📈</div>
      <h2 class="text-xl font-medium mb-1" style="font-family:'ZCOOL XiaoWei',sans-serif">近30天情绪曲线</h2>
      <p class="text-sm" style="color:var(--text-soft)">看见情绪的起伏，也是显化的一部分</p>
    </div>
    
    <div id="mood-chart-stats"></div>
    
    <div class="glass-card p-4 mb-4" style="height:280px">
      <canvas id="mood-chart-canvas"></canvas>
    </div>
    
    <div class="glass-card p-4">
      <h3 class="text-sm font-medium mb-2" style="color:var(--theme-text)">📖 如何解读</h3>
      <div class="text-xs space-y-1" style="color:var(--text-soft)">
        <p>• 情绪值 1-7：需要关爱和休息</p>
        <p>• 情绪值 8-14：平静稳定</p>
        <p>• 情绪值 15-21：积极喜悦</p>
        <p>• 曲线向上：能量在提升</p>
        <p>• 曲线向下：需要更多自我关怀</p>
      </div>
    </div>
  </div>
</section>

