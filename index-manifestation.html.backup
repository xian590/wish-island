  { q: '周末你更想怎么度过？', options: [
    { text: '约朋友出去玩，参加各种活动', scores: { action: 3, create: 1, empathy: 1, stable: 0, charm: 2 } },
    { text: '在家看书追剧，做自己喜欢的事', scores: { action: 0, create: 3, empathy: 1, stable: 2, charm: 0 } },
    { text: '安安静静待着，怎么舒服怎么来', scores: { action: 0, create: 1, empathy: 1, stable: 3, charm: 0 } },
    { text: '和闺蜜聊天，陪伴帮助别人', scores: { action: 1, create: 0, empathy: 3, stable: 1, charm: 1 } },
    { text: '打扮得美美的，去拍照打卡', scores: { action: 2, create: 2, empathy: 0, stable: 0, charm: 3 } },
