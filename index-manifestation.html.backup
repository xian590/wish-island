    </div>

    <div class="mb-4 flex gap-2">
      <input type="text" id="vision-input" class="dream-input flex-1 text-sm" placeholder="写下你的愿望...（如：2025年拥有梦想的房子）">
      <button onclick="addVisionCard()" class="btn-primary px-4 py-2 rounded-xl text-sm">添加</button>
    </div>

    <div id="vision-board" class="grid grid-cols-2 gap-3" style="perspective:800px">
      <!-- 卡片将在这里动态生成 -->
    </div>

