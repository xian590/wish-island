    <!-- ========== 页面2：星光水晶测试神殿 ========== -->
    <section id="page-temple" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">💎 星光水晶测试神殿</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        第1步 · 自我认知<br/>
        <span class="text-xs">了解你是谁，才能知道你要去哪里。温柔地看见真实的自己吧 ✨</span>
      </p>

      <div class="grid sm:grid-cols-3 gap-4 mb-6">
        <div class="glass-card p-4 card-hover cursor-pointer" onclick="startTest('personality')">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-3 shadow-soft" style="background:linear-gradient(135deg, #F5E1EA, #D4B5C7)">
            👑
          </div>
          <h3 class="font-title text-base mb-1" style="color:var(--theme-text)">人格测试 · 快速版</h3>
          <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.6">15题 · 5特质匹配12人格</p>
          <div class="flex items-center justify-between text-xs">
            <span style="color:var(--theme-text); opacity:0.5">⏱ 约3分钟</span>
            <span class="px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(184,169,201,0.15); color:#8B7E9C">+30💎</span>
          </div>
        </div>
        <div class="glass-card p-4 card-hover cursor-pointer" onclick="startTest('personality_deep')">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-3 shadow-soft" style="background:linear-gradient(135deg, #D4C5E0, #9D8BB0)">
            💎
          </div>
          <h3 class="font-title text-base mb-1" style="color:var(--theme-text)">人格测试 · 深度版</h3>
          <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.6">45题 · 更精准的人格画像</p>
          <div class="flex items-center justify-between text-xs">
            <span style="color:var(--theme-text); opacity:0.5">⏱ 约10分钟</span>
            <span class="px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(212,181,199,0.2); color:#B8859C">+80💎</span>
          </div>
        </div>
        <div class="glass-card p-4 card-hover cursor-pointer" onclick="startTest('belief')">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-3 shadow-soft" style="background:linear-gradient(135deg, #D4C5E0, #9D8BB0)">
            🔍
          </div>
          <h3 class="font-title text-base mb-1" style="color:var(--theme-text)">限制性信念探测</h3>
          <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.6">20题 · 找出核心卡点信念</p>
          <div class="flex items-center justify-between text-xs">
            <span style="color:var(--theme-text); opacity:0.5">⏱ 约5分钟</span>
            <span class="px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(212,181,199,0.2); color:#B8859C">+30💎</span>
          </div>
        </div>
        <div class="glass-card p-4 card-hover cursor-pointer" onclick="startTest('emotion')">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-3 shadow-soft" style="background:linear-gradient(135deg, #DDEBE0, #88C898)">
            🌈
          </div>
          <h3 class="font-title text-base mb-1" style="color:var(--theme-text)">情绪刻度测试</h3>
          <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.6">亚伯拉罕22级情绪刻度定位</p>
          <div class="flex items-center justify-between text-xs">
            <span style="color:var(--theme-text); opacity:0.5">⏱ 约3分钟</span>
            <span class="px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(136,200,152,0.25); color:#5A9C6A">+20💎</span>
          </div>
        </div>
      </div>

      <div class="glass-card p-5 mb-5">
        <h4 class="font-title text-base mb-3" style="color:var(--theme-text)">✨ 12位显化公主</h4>
        <div class="grid grid-cols-4 sm:grid-cols-6 gap-3" id="persona-preview"></div>
        <p class="text-center text-xs mt-3" style="color:var(--theme-text); opacity:0.4">完成测试解锁你的专属公主身份 🌸</p>
      </div>

      <div class="glass-card p-5">
        <h4 class="font-title text-base mb-3" style="color:var(--theme-text)">📊 五大显化特质</h4>
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 text-center text-xs">
          <div class="p-3 rounded-xl" style="background:rgba(212,165,184,0.12)">
            <div class="text-2xl mb-1">🔥</div>
            <div class="font-title" style="color:var(--theme-text)">行动力</div>
            <div class="mt-1 leading-snug" style="color:var(--theme-text); opacity:0.6">敢想敢做<br/>执行力强</div>
          </div>
          <div class="p-3 rounded-xl" style="background:rgba(184,169,201,0.15)">
            <div class="text-2xl mb-1">🎨</div>
            <div class="font-title" style="color:var(--theme-text)">创造力</div>
            <div class="mt-1 leading-snug" style="color:var(--theme-text); opacity:0.6">想象力丰富<br/>视觉化强</div>
          </div>
          <div class="p-3 rounded-xl" style="background:rgba(240,213,224,0.2)">
            <div class="text-2xl mb-1">💗</div>
            <div class="font-title" style="color:var(--theme-text)">共情力</div>
            <div class="mt-1 leading-snug" style="color:var(--theme-text); opacity:0.6">感知敏锐<br/>温柔善良</div>
          </div>
          <div class="p-3 rounded-xl" style="background:rgba(136,200,152,0.15)">
            <div class="text-2xl mb-1">🌿</div>
            <div class="font-title" style="color:var(--theme-text)">稳定力</div>
            <div class="mt-1 leading-snug" style="color:var(--theme-text); opacity:0.6">踏实坚持<br/>信念稳固</div>
          </div>
          <div class="p-3 rounded-xl" style="background:rgba(245,230,200,0.3)">
            <div class="text-2xl mb-1">✨</div>
            <div class="font-title" style="color:var(--theme-text)">魅力值</div>
            <div class="mt-1 leading-snug" style="color:var(--theme-text); opacity:0.6">自信闪耀<br/>吸引力强</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 页面3：信念净化塔 ========== -->
    <section id="page-tower" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">🔮 信念净化塔</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        第2步 · 信念清理<br/>
        <span class="text-xs">信念是显化的根基。清理掉限制性信念，你才能轻盈地起飞 🦋</span>
      </p>

      <div class="grid lg:grid-cols-2 gap-5">
        <!-- CBT信念净化 -->
        <div class="glass-card p-5">
          <h3 class="font-title text-base mb-2 flex items-center gap-2" style="color:var(--theme-text)">
            <span>💎</span> CBT信念净化
          </h3>
          <p class="text-xs mb-4" style="color:var(--theme-text); opacity:0.6">6步认知行为疗法，把负面想法变成闪闪发光的正面信念 ✨</p>

          <!-- 步骤指示器 -->
          <div class="flex items-center justify-between mb-4 px-1">
            <div class="flex flex-col items-center">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium cbt-step-1" id="cbt-step-1" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">1</div>
            </div>
            <div class="h-px flex-1 mx-1" style="background:rgba(184,169,201,0.2)"></div>
            <div class="flex flex-col items-center">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium cbt-step-2" id="cbt-step-2" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">2</div>
            </div>
            <div class="h-px flex-1 mx-1" style="background:rgba(184,169,201,0.2)"></div>
            <div class="flex flex-col items-center">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium cbt-step-3" id="cbt-step-3" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">3</div>
            </div>
            <div class="h-px flex-1 mx-1" style="background:rgba(184,169,201,0.2)"></div>
            <div class="flex flex-col items-center">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium cbt-step-4" id="cbt-step-4" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">4</div>
            </div>
            <div class="h-px flex-1 mx-1" style="background:rgba(184,169,201,0.2)"></div>
            <div class="flex flex-col items-center">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium cbt-step-5" id="cbt-step-5" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">5</div>
            </div>
            <div class="h-px flex-1 mx-1" style="background:rgba(184,169,201,0.2)"></div>
            <div class="flex flex-col items-center">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium cbt-step-6" id="cbt-step-6" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">6</div>
            </div>
          </div>

          <div id="cbt-container">
            <!-- 步骤1：事件描述 -->
            <div id="cbt-step1" class="cbt-step-content">
              <div class="text-xs font-medium mb-2" style="color:#D4A5B8">第1步 · 客观描述事件</div>
              <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.75"><b>💡 什么是「客观描述」？</b>只说事实，不加任何评价、判断、猜测。就像一台摄像机在记录一样，只拍发生了什么，不解释「为什么」。</p>
              <div class="p-2.5 rounded-xl mb-3" style="background:rgba(240,213,224,0.15)">
                <div class="text-[10px] font-medium mb-1" style="color:#B8859C">📌 举个例子</div>
                <div class="text-[10px] space-y-1" style="color:var(--theme-text); opacity:0.75">
                  <p>❌ 不是：「他不爱我了」（这是你的判断）</p>
                  <p>❌ 不是：「他故意不理我」（这是你的猜测）</p>
                  <p>✅ 而是：「他已经2小时没回我消息了」（这是事实）</p>
                </div>
              </div>
              <textarea id="cbt-event" placeholder="今天发生了什么具体的事？只写事实，不加评价～" rows="2" class="dream-input text-sm"></textarea>
              <button onclick="nextCBTStep(2)" class="soft-btn btn-primary w-full py-2.5 mt-3 text-sm font-title">下一步 →</button>
            </div>

            <!-- 步骤2：自动想法 -->
            <div id="cbt-step2" class="cbt-step-content hidden">
              <div class="text-xs font-medium mb-2" style="color:#B8A9C9">第2步 · 捕捉自动想法</div>
              <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.75"><b>💡 什么是「自动想法」？</b>就是事情发生的那一刻，你脑子里第一时间冒出来的那个念头。它可能很快、很模糊，但它决定了你的情绪。不用评判它对不对，诚实写下来就好。</p>
              <div class="p-2.5 rounded-xl mb-3" style="background:rgba(184,169,201,0.12)">
                <div class="text-[10px] font-medium mb-1" style="color:#8B7E9C">📌 举个例子</div>
                <div class="text-[10px] space-y-1" style="color:var(--theme-text); opacity:0.75">
                  <p>💭 「他肯定不爱我了」</p>
                  <p>💭 「我什么都做不好」</p>
                  <p>💭 「别人都觉得我很蠢」</p>
                  <p class="opacity-60">... 你当时的第一想法是什么？</p>
                </div>
              </div>
              <textarea id="cbt-thought" placeholder="我当时的第一想法是..." rows="2" class="dream-input text-sm"></textarea>
              <div class="flex gap-2 mt-3">
                <button onclick="prevCBTStep(1)" class="soft-btn btn-soft flex-1 py-2.5 text-sm">← 上一步</button>
                <button onclick="nextCBTStep(3)" class="soft-btn btn-primary flex-1 py-2.5 text-sm font-title">下一步 →</button>
              </div>
            </div>

            <!-- 步骤3：认知歪曲选择 -->
            <div id="cbt-step3" class="cbt-step-content hidden">
              <div class="text-xs font-medium mb-2" style="color:#9DB5C8">第3步 · 识别认知歪曲</div>
              <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.75"><b>💡 什么是「认知歪曲」？</b>就是你的大脑「自动」产生的、不符合客观事实的思维偏差。每个人都有，这很正常。识别出它们，就是改变的第一步。</p>
              <p class="text-xs mb-3" style="color:var(--theme-text); opacity:0.6">你的这个想法，属于下面哪种思维陷阱呢？可以选多个～</p>
              <div class="space-y-2" id="distortion-options">
                ${COGNITIVE_DISTORTIONS.map((d, i) => `
                  <div class="p-2.5 rounded-xl cursor-pointer transition distortion-option" onclick="toggleDistortion(${i}, this)" data-index="${i}" style="background:rgba(184,169,201,0.08); border:1.5px solid transparent">
                    <div class="text-xs font-medium mb-0.5" style="color:var(--theme-text)">${d.name}</div>
                    <div class="text-[10px] mb-1" style="color:var(--theme-text); opacity:0.6">${d.desc}</div>
                    <div class="text-[10px] italic" style="color:var(--theme-text); opacity:0.4">例如：${d.example || ''}</div>
                  </div>
                `).join('')}
              </div>
              <div class="flex gap-2 mt-3">
                <button onclick="prevCBTStep(2)" class="soft-btn btn-soft flex-1 py-2.5 text-sm">← 上一步</button>
                <button onclick="nextCBTStep(4)" class="soft-btn btn-primary flex-1 py-2.5 text-sm font-title">下一步 →</button>
              </div>
            </div>

            <!-- 步骤4：反驳证据 -->
            <div id="cbt-step4" class="cbt-step-content hidden">
              <div class="text-xs font-medium mb-2" style="color:#88C898">第4步 · 寻找反驳证据</div>
              <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.75"><b>💡 为什么要找证据？</b>负面想法之所以有力量，是因为你相信它是真的。但当你真的去找证据时，会发现它根本站不住脚。哪怕只有一点点反面证据，也说明这个想法不是100%正确的。</p>
              <div class="p-2.5 rounded-xl mb-3" style="background:rgba(136,200,152,0.15)">
                <div class="text-[10px] font-medium mb-1" style="color:#5A9C6A">📌 举个例子</div>
                <div class="text-[10px] space-y-1" style="color:var(--theme-text); opacity:0.75">
                  <p>🔍 想法：「他不爱我了」</p>
                  <p>✅ 反驳证据1：他上次秒回了我，还主动找我聊天</p>
                  <p>✅ 反驳证据2：他之前也有忙的时候没回，后来跟我解释了</p>
                  <p>✅ 反驳证据3：他上周还送了我礼物</p>
                </div>
              </div>
              <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.6">有什么客观事实可以证明这个想法不一定是对的？</p>
              <textarea id="cbt-evidence-input" placeholder="写下你能想到的所有反面证据，哪怕很小的也算～" rows="3" class="dream-input text-sm"></textarea>
              <div class="flex gap-2 mt-3">
                <button onclick="prevCBTStep(3)" class="soft-btn btn-soft flex-1 py-2.5 text-sm">← 上一步</button>
                <button onclick="nextCBTStep(5)" class="soft-btn btn-primary flex-1 py-2.5 text-sm font-title">下一步 →</button>
              </div>
            </div>

            <!-- 步骤5：替代想法 -->
            <div id="cbt-step5" class="cbt-step-content hidden">
              <div class="text-xs font-medium mb-2" style="color:#E8C87A">第5步 · 生成替代想法</div>
              <p class="text-xs mb-3" style="color:var(--theme-text); opacity:0.6">基于客观证据，更合理、更平衡的想法是什么呢？系统也为你提供了参考～</p>
              <div class="p-3 rounded-xl mb-3" style="background:rgba(245,230,200,0.25)">
                <div class="text-[10px] mb-1" style="color:var(--theme-text); opacity:0.5">💡 系统建议的替代想法</div>
                <div class="text-sm" style="color:var(--theme-text)" id="cbt-suggestion"></div>
              </div>
              <textarea id="cbt-alternative" placeholder="写下你觉得更合理的想法..." rows="2" class="dream-input text-sm"></textarea>
              <div class="flex gap-2 mt-3">
                <button onclick="prevCBTStep(4)" class="soft-btn btn-soft flex-1 py-2.5 text-sm">← 上一步</button>
                <button onclick="nextCBTStep(6)" class="soft-btn btn-primary flex-1 py-2.5 text-sm font-title">开始净化 ✨</button>
              </div>
            </div>

            <!-- 步骤6：净化动画 -->
            <div id="cbt-step6" class="cbt-step-content hidden text-center">
              <div class="text-xs font-medium mb-4" style="color:#F5E6C8">第6步 · 信念净化中</div>
              
              <div id="neg-crystal-stage" class="mb-4">
                <div class="neg-crystal mx-auto" id="cbt-neg-crystal">
                  <div class="text-xs opacity-70 mb-1">⚫ 负面信念</div>
                  <div class="text-sm" id="cbt-neg-display"></div>
                </div>
              </div>

              <div class="text-xs mb-4" style="color:var(--theme-text); opacity:0.4" id="purify-status-text">星光水晶正在碎裂...</div>

              <div id="pos-crystal-stage" class="hidden">
                <div class="pos-crystal mx-auto animate-soft-pop" id="cbt-pos-crystal">
                  <div class="text-xs opacity-80 mb-1">💛 净化后的正面信念</div>
                  <div class="text-sm font-medium" id="cbt-pos-display"></div>
                </div>
                <p class="text-xs mt-4" style="color:var(--theme-text); opacity:0.6">你看，这个想法不是真的呀～</p>
              </div>

              <button onclick="completeCBTPurify()" id="cbt-complete-btn" class="soft-btn w-full py-2.5 mt-4 text-sm font-title hidden" style="background:linear-gradient(135deg, #F5E6C8, #E8C87A); color:#78350F; box-shadow:0 4px 14px rgba(245,158,11,0.3)">
                💫 完成净化 +20能量
              </button>
            </div>
          </div>

          <!-- CBT 历史记录 -->
          <div class="glass-card p-5 mt-5">
            <h3 class="font-title text-base mb-3 flex items-center gap-2" style="color:var(--theme-text)">
              <span>📜</span> 净化记录
            </h3>
            <div id="cbt-records-list" class="space-y-2"></div>
          </div>
        </div>

        <!-- 修正法冥想 -->
        <div class="glass-card p-5">
          <h3 class="font-title text-base mb-2 flex items-center gap-2" style="color:var(--theme-text)">
            <span>🕊️</span> 修正法疗愈冥想
          </h3>
          <p class="text-xs mb-3" style="color:var(--theme-text); opacity:0.6">倒带回放负面记忆，在想象里改写结局，给潜意识输入新记忆</p>

          <div class="grid grid-cols-2 gap-2.5 mb-4">
            <button class="p-3 rounded-xl transition text-center card-hover" style="background:rgba(240,213,224,0.2)" onclick="startRevision('原生家庭')">
              <div class="text-xl mb-1">🏠</div>
              <div class="text-xs" style="color:var(--theme-text)">原生家庭</div>
            </button>
            <button class="p-3 rounded-xl transition text-center card-hover" style="background:rgba(212,165,184,0.15)" onclick="startRevision('失恋创伤')">
              <div class="text-xl mb-1">💔</div>
              <div class="text-xs" style="color:var(--theme-text)">失恋创伤</div>
            </button>
            <button class="p-3 rounded-xl transition text-center card-hover" style="background:rgba(184,169,201,0.15)" onclick="startRevision('失败经历')">
              <div class="text-xl mb-1">💪</div>
              <div class="text-xs" style="color:var(--theme-text)">失败经历</div>
            </button>
            <button class="p-3 rounded-xl transition text-center card-hover" style="background:rgba(245,213,213,0.25)" onclick="startRevision('容貌焦虑')">
              <div class="text-xl mb-1">🌸</div>
              <div class="text-xs" style="color:var(--theme-text)">容貌焦虑</div>
            </button>
          </div>

           <div id="revision-area" class="hidden">
             <div class="breath-circle mb-3">
               <div class="breath-circle-inner" id="revision-breath-text">吸气</div>
             </div>
             <div class="text-center text-xs mb-3" style="color:var(--theme-text); opacity:0.5" id="revision-timer">00:00 / 10:00</div>
             <div class="p-4 rounded-2xl mb-3" style="background:linear-gradient(135deg, rgba(184,169,201,0.1), rgba(212,181,199,0.08))">
               <h4 class="font-title text-sm mb-2" style="color:var(--theme-text)" id="revision-title">冥想引导</h4>
               <div class="text-xs space-y-2 leading-relaxed" style="color:var(--theme-text); opacity:0.8" id="revision-text"></div>
             </div>
             <div class="flex gap-2 mb-3">
               <button onclick="toggleRevision()" id="revision-toggle-btn" class="soft-btn btn-primary flex-1 py-2 text-sm">
                 ▶️ 开始
               </button>
               <button onclick="stopRevision()" class="soft-btn btn-soft px-4 py-2 text-sm">
                 结束
               </button>
             </div>
             <!-- 冥想感受记录 -->
             <div class="p-3 rounded-2xl" style="background:rgba(240,213,224,0.1); border:1px solid rgba(240,213,224,0.2)">
               <div class="text-xs font-medium mb-2 flex items-center gap-1" style="color:#B8859C">
                 <span>📝</span> 练习感受记录
               </div>
               <textarea id="revision-note" oninput="saveRevisionNote()" placeholder="做完冥想有什么感受？想象中的新记忆是什么样的？写下来吧～" rows="3" class="w-full p-3 rounded-xl text-xs resize-none outline-none" style="background:rgba(255,255,255,0.5); backdrop-filter:blur(10px); color:var(--theme-text); border:1px solid rgba(184,169,201,0.15)"></textarea>
               <div class="text-[10px] mt-1.5 flex items-center justify-between" style="color:var(--theme-text); opacity:0.4">
                 <span>💡 内容会自动保存哦</span>
                 <span id="revision-note-status"></span>
               </div>
             </div>
           </div>
        </div>
      </div>

      <!-- 21天打卡 -->
      <div class="glass-card p-5 mt-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-title text-base flex items-center gap-2" style="color:var(--theme-text)">
            <span>📅</span> 21天信念净化显化挑战
          </h3>
          <span class="level-badge">第 <span id="purify-day">0</span> 天</span>
        </div>
        <div class="w-full h-2.5 rounded-full overflow-hidden mb-3" style="background:rgba(184,169,201,0.12)">
          <div class="h-full progress-fill rounded-full" style="background:linear-gradient(90deg, #D4B5C7, #B8A9C9, #9D8BB0)" id="purify-progress" style="width:0%"></div>
        </div>
        <div class="flex justify-between text-xs mb-4" style="color:var(--theme-text); opacity:0.5">
          <span>第1天</span>
          <span>第21天 · 信念净化师徽章</span>
        </div>
        <div class="grid grid-cols-7 gap-1.5" id="purify-calendar"></div>
        <div class="mt-4 p-3 rounded-xl" style="background:linear-gradient(135deg, rgba(184,169,201,0.1), rgba(212,181,199,0.08))">
          <div class="text-xs mb-1" style="color:var(--theme-text); opacity:0.6">💡 今日净化小贴士</div>
          <div class="text-xs" style="color:var(--theme-text)" id="purify-tip">
            每当你觉察到负面想法时，轻轻说"我看到你了，但我选择相信更好的"。
          </div>
        </div>
      </div>

      <!-- 统计 -->
      <div class="glass-card p-5 mt-5">
        <h4 class="font-title text-base mb-3" style="color:var(--theme-text)">📊 已净化信念统计</h4>
        <div class="grid grid-cols-3 gap-3 mb-4 text-center">
          <div class="p-3 rounded-xl" style="background:rgba(212,165,184,0.12)">
            <div class="text-2xl font-title" style="color:#D4A5B8" id="purify-total">0</div>
            <div class="text-xs" style="color:var(--theme-text); opacity:0.6">总净化数</div>
          </div>
          <div class="p-3 rounded-xl" style="background:rgba(184,169,201,0.15)">
            <div class="text-2xl font-title" style="color:#8B7E9C" id="purify-today">0</div>
            <div class="text-xs" style="color:var(--theme-text); opacity:0.6">今日净化</div>
          </div>
          <div class="p-3 rounded-xl" style="background:rgba(245,230,200,0.3)">
            <div class="text-2xl font-title" style="color:#D4A85A" id="purify-streak">0</div>
            <div class="text-xs" style="color:var(--theme-text); opacity:0.6">连续天数</div>
          </div>
        </div>
        <div id="purify-stats" class="space-y-2">
          <div class="text-center py-4 text-sm" style="color:var(--theme-text); opacity:0.4">还没有数据，开始第一次净化吧～</div>
        </div>
      </div>
    </section>

    <!-- ========== 页面4：许愿星台 ========== -->
    <section id="page-stars" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">⭐ 许愿星台</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        第3步 · 清晰愿景<br/>
        <span class="text-xs">用BE-DO-HAVE模型写下你的愿望，越具体越容易实现 🌠</span>
      </p>

      <div class="grid lg:grid-cols-2 gap-5">
        <!-- 写愿望 -->
        <div class="glass-card p-5">
          <h3 class="font-title text-base mb-3" style="color:var(--theme-text)">✍️ 写下你的愿望</h3>

          <div class="mb-4">
            <label class="text-xs mb-2 block" style="color:var(--theme-text); opacity:0.6">愿望类型</label>
            <div class="flex gap-2 flex-wrap" id="wish-types">
              <button class="chip-soft" data-type="love" onclick="selectWishType('love', this)">💖 恋爱SP</button>
              <button class="chip-soft" data-type="money" onclick="selectWishType('money', this)">💰 财富事业</button>
              <button class="chip-soft" data-type="beauty" onclick="selectWishType('beauty', this)">✨ 美貌自信</button>
              <button class="chip-soft" data-type="heal" onclick="selectWishType('heal', this)">🧘 情绪疗愈</button>
              <button class="chip-soft" data-type="life" onclick="selectWishType('life', this)">🏠 生活方式</button>
              <button class="chip-soft" data-type="study" onclick="selectWishType('study', this)">📚 考试学习</button>
            </div>
          </div>

          <div class="space-y-3">
            <div class="p-4 rounded-xl" style="background:rgba(240,213,224,0.15)">
              <div class="text-xs font-medium mb-2" style="color:#B8859C">💫 BE · 你成为了什么样的人？</div>
               <textarea id="wish-be" oninput="saveWishDraft()" placeholder="例：我是被坚定爱着的女朋友，自信又松弛..." rows="2" class="dream-input text-sm" style="background:rgba(255,255,255,0.7)"></textarea>
              <p class="text-[10px] mt-1" style="color:var(--theme-text); opacity:0.45">💡 用"我是..."开头，描述你想成为的身份</p>
            </div>
            <div class="p-4 rounded-xl" style="background:rgba(184,169,201,0.12)">
              <div class="text-xs font-medium mb-2" style="color:#8B7E9C">🎬 DO · 你每天会做什么事？</div>
               <textarea id="wish-do" oninput="saveWishDraft()" placeholder="例：我们每天一起吃早餐，他会摸我的头叫我宝宝..." rows="2" class="dream-input text-sm" style="background:rgba(255,255,255,0.7)"></textarea>
              <p class="text-[10px] mt-1" style="color:var(--theme-text); opacity:0.45">💡 具体的日常场景，越细节越好</p>
            </div>
            <div class="p-4 rounded-xl" style="background:rgba(201,216,232,0.2)">
              <div class="text-xs font-medium mb-2" style="color:#7A8FA8">💎 HAVE · 你拥有了什么？</div>
               <textarea id="wish-have" oninput="saveWishDraft()" placeholder="例：我们已经在一起了，他主动发消息，记得我所有喜好..." rows="2" class="dream-input text-sm" style="background:rgba(255,255,255,0.7)"></textarea>
              <p class="text-[10px] mt-1" style="color:var(--theme-text); opacity:0.45">💡 具体拥有的东西/状态，用现在时</p>
            </div>
            <div class="p-4 rounded-xl" style="background:rgba(245,230,200,0.25)">
              <div class="text-xs font-medium mb-2" style="color:#B8955A">👁️ 多感官终点场景</div>
              <div class="grid grid-cols-2 gap-2">
                <div>
                  <label class="text-[10px]" style="color:var(--theme-text); opacity:0.5">👀 看到什么？</label>
                   <input type="text" id="wish-sight" oninput="saveWishDraft()" placeholder="例：他笑着朝我走来" class="dream-input text-xs !p-2 !mt-1">
                </div>
                <div>
                  <label class="text-[10px]" style="color:var(--theme-text); opacity:0.5">👂 听到什么？</label>
                   <input type="text" id="wish-sound" oninput="saveWishDraft()" placeholder="例：他说我爱你" class="dream-input text-xs !p-2 !mt-1">
                </div>
                <div>
                  <label class="text-[10px]" style="color:var(--theme-text); opacity:0.5">🤲 摸到什么？</label>
                   <input type="text" id="wish-touch" oninput="saveWishDraft()" placeholder="例：他的手很温暖" class="dream-input text-xs !p-2 !mt-1">
                </div>
                <div>
                  <label class="text-[10px]" style="color:var(--theme-text); opacity:0.5">💗 心里感觉？</label>
                   <input type="text" id="wish-feel" oninput="saveWishDraft()" placeholder="例：安心又甜蜜" class="dream-input text-xs !p-2 !mt-1">
                </div>
              </div>
              <div class="mt-2">
                <label class="text-[10px]" style="color:var(--theme-text); opacity:0.5">✨ 愿望实现后的第一个小动作？</label>
                 <input type="text" id="wish-first-action" oninput="saveWishDraft()" placeholder="例：朋友拍我肩膀说你俩也太甜了" class="dream-input text-xs !p-2 !mt-1">
              </div>
            </div>
          </div>

          <button onclick="createWishStar()" class="soft-btn btn-primary w-full py-3 mt-4 text-sm font-title">
            ⭐ 生成许愿星
          </button>
        </div>

        <!-- 星空 -->
        <div>
          <div class="glass-card p-5 mb-4">
            <h3 class="font-title text-base mb-3" style="color:var(--theme-text)">🌌 把星星放上你的星空</h3>
            <div class="starry-sky relative" id="wish-sky" style="min-height: 320px">
              <div class="absolute inset-0 p-4 text-center">
                <p class="text-white/50 text-xs mt-2">生成许愿星后，把它拖到天上吧～</p>
              </div>
              <div id="sky-wishes"></div>
              <div id="pending-star" class="hidden wish-star" style="bottom:20px; left:50%; transform:translateX(-50%)">
                ⭐
              </div>
            </div>
          </div>

          <div class="glass-card p-4">
            <div class="flex items-center justify-between mb-3">
              <h4 class="font-title text-sm" style="color:var(--theme-text)">📜 我的愿望清单</h4>
              <span class="text-xs" style="color:var(--theme-text); opacity:0.5"><span id="wish-count">0</span> 个愿望</span>
            </div>
            <div id="wish-list" class="space-y-2 max-h-60 overflow-y-auto pr-1">
              <div class="text-center py-6 text-sm" style="color:var(--theme-text); opacity:0.4">
                还没有愿望，向宇宙下第一个订单吧 🌠
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 页面5：云端冥想城堡 ========== -->
    <section id="page-cloud" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">☁️ 云端冥想城堡</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        第4步 · 状态对齐<br/>
        <span class="text-xs">调整到愿望已经实现的频率，你就在显化的终点了 🧘‍♀️</span>
      </p>

      <!-- SATS冥想 -->
      <div class="glass-card p-5 mb-5">
        <h3 class="font-title text-base mb-3 flex items-center gap-2" style="color:var(--theme-text)">
          <span>🌙</span> SATS睡前视觉化冥想
        </h3>
        <p class="text-xs mb-4" style="color:var(--theme-text); opacity:0.6">半梦半醒时视觉化终点场景，是最强效的显化时间</p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
          <button class="p-4 rounded-xl transition text-center card-hover" style="background:rgba(240,213,224,0.2)" onclick="startSATS('恋爱SP')">
            <div class="text-2xl mb-1">💖</div>
            <div class="text-xs" style="color:var(--theme-text)">恋爱SP</div>
          </button>
          <button class="p-4 rounded-xl transition text-center card-hover" style="background:rgba(245,230,200,0.3)" onclick="startSATS('财富事业')">
            <div class="text-2xl mb-1">💰</div>
            <div class="text-xs" style="color:var(--theme-text)">财富事业</div>
          </button>
          <button class="p-4 rounded-xl transition text-center card-hover" style="background:rgba(245,213,213,0.25)" onclick="startSATS('美貌自信')">
            <div class="text-2xl mb-1">✨</div>
            <div class="text-xs" style="color:var(--theme-text)">美貌自信</div>
          </button>
          <button class="p-4 rounded-xl transition text-center card-hover" style="background:rgba(221,235,224,0.3)" onclick="startSATS('情绪疗愈')">
            <div class="text-2xl mb-1">🧘</div>
            <div class="text-xs" style="color:var(--theme-text)">情绪疗愈</div>
          </button>
        </div>

        <div id="sats-area" class="hidden">
          <!-- SATS步骤指示器 -->
          <div class="flex items-center justify-between mb-4 px-1">
            <div class="flex flex-col items-center flex-1">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium sats-step-dot" id="sats-dot-1" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">1</div>
              <div class="text-[10px] mt-1" style="color:var(--theme-text); opacity:0.5">放松</div>
            </div>
            <div class="h-px flex-1 mx-0.5" style="background:rgba(184,169,201,0.2)"></div>
            <div class="flex flex-col items-center flex-1">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium sats-step-dot" id="sats-dot-2" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">2</div>
              <div class="text-[10px] mt-1" style="color:var(--theme-text); opacity:0.5">入境</div>
            </div>
            <div class="h-px flex-1 mx-0.5" style="background:rgba(184,169,201,0.2)"></div>
            <div class="flex flex-col items-center flex-1">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium sats-step-dot" id="sats-dot-3" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">3</div>
              <div class="text-[10px] mt-1" style="color:var(--theme-text); opacity:0.5">构建</div>
            </div>
            <div class="h-px flex-1 mx-0.5" style="background:rgba(184,169,201,0.2)"></div>
            <div class="flex flex-col items-center flex-1">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium sats-step-dot" id="sats-dot-4" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">4</div>
              <div class="text-[10px] mt-1" style="color:var(--theme-text); opacity:0.5">循环</div>
            </div>
            <div class="h-px flex-1 mx-0.5" style="background:rgba(184,169,201,0.2)"></div>
            <div class="flex flex-col items-center flex-1">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium sats-step-dot" id="sats-dot-5" style="background:rgba(184,169,201,0.15); color:var(--theme-text); opacity:0.5">5</div>
              <div class="text-[10px] mt-1" style="color:var(--theme-text); opacity:0.5">完成</div>
            </div>
          </div>

          <div class="breath-circle mb-3">
            <div class="breath-circle-inner" id="sats-breath-text">吸气</div>
          </div>
          <div class="text-center text-xs mb-3" style="color:var(--theme-text); opacity:0.5" id="sats-timer">00:00 / 15:00</div>
          <div class="p-4 rounded-2xl mb-3" style="background:linear-gradient(135deg, rgba(201,216,232,0.2), rgba(184,169,201,0.1))">
            <h4 class="font-title text-sm mb-2" style="color:var(--theme-text)" id="sats-title">SATS引导</h4>
            <div class="text-xs space-y-2 leading-relaxed" style="color:var(--theme-text); opacity:0.8" id="sats-text"></div>
          </div>
          <div class="flex gap-2 mb-3">
             <button onclick="toggleSATS()" id="sats-toggle-btn" class="soft-btn btn-primary flex-1 py-2 text-sm">
               ▶️ 开始
             </button>
             <button onclick="stopSATS()" class="soft-btn btn-soft px-4 py-2 text-sm">
               结束
             </button>
           </div>
           <!-- SATS终点场景记录 -->
           <div class="p-3 rounded-2xl" style="background:rgba(201,216,232,0.15); border:1px solid rgba(201,216,232,0.2)">
             <div class="text-xs font-medium mb-2 flex items-center gap-1" style="color:#7A8FA8">
               <span>🌙</span> 我的终点场景
             </div>
             <textarea id="sats-scene" oninput="saveSATSScene()" placeholder="今天视觉化的终点场景是什么？具体描述一下你看到的、听到的、感受到的..." rows="2" class="w-full p-3 rounded-xl text-xs resize-none outline-none" style="background:rgba(255,255,255,0.5); backdrop-filter:blur(10px); color:var(--theme-text); border:1px solid rgba(184,169,201,0.15)"></textarea>
             <div class="text-[10px] mt-1.5 mb-2" style="color:var(--theme-text); opacity:0.4">💡 写得越具体，显化越快哦</div>
             <div class="text-xs font-medium mb-1.5 flex items-center gap-1" style="color:#B8859C">
               <span>💗</span> 练习感受
             </div>
             <textarea id="sats-feeling" oninput="saveSATSScene()" placeholder="做完冥想有什么感受？心情怎么样？有没有什么特别的体验？" rows="2" class="w-full p-3 rounded-xl text-xs resize-none outline-none" style="background:rgba(255,255,255,0.5); backdrop-filter:blur(10px); color:var(--theme-text); border:1px solid rgba(184,169,201,0.15)"></textarea>
             <div class="text-[10px] mt-1.5 flex items-center justify-between" style="color:var(--theme-text); opacity:0.4">
               <span>💫 内容自动保存</span>
               <span id="sats-save-status"></span>
             </div>
           </div>
         </div>
      </div>

      <!-- 精神节食 -->
      <div class="glass-card p-5 mb-5">
        <h3 class="font-title text-base mb-3 flex items-center gap-2" style="color:var(--theme-text)">
          <span>🥗</span> 21天精神节食
        </h3>
        <p class="text-xs mb-4" style="color:var(--theme-text); opacity:0.6">觉察负面想法，立刻替换成正面肯定语，21天养成新思维习惯</p>

        <!-- 进度条 -->
        <div class="mb-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs" style="color:var(--theme-text); opacity:0.6">21天显化挑战进度</span>
            <span class="text-xs font-medium" style="color:#B8A9C9">第 <span id="md-day">0</span> / 21 天</span>
          </div>
          <div class="w-full h-2.5 rounded-full overflow-hidden" style="background:rgba(184,169,201,0.12)">
            <div class="h-full progress-fill rounded-full" style="background:linear-gradient(90deg, #D4B5C7, #B8A9C9, #9DB5C8)" id="md-progress" style="width:0%"></div>
          </div>
        </div>

        <!-- 今日统计 -->
        <div class="grid grid-cols-3 gap-3 mb-4 text-center">
          <div class="p-3 rounded-xl" style="background:rgba(245,213,213,0.15)">
            <div class="text-2xl font-title" style="color:#B87590" id="md-today-count">0</div>
            <div class="text-xs" style="color:var(--theme-text); opacity:0.6">今日觉察</div>
          </div>
          <div class="p-3 rounded-xl" style="background:rgba(212,181,199,0.2)">
            <div class="text-2xl font-title" style="color:#8B7E9C" id="md-total-count">0</div>
            <div class="text-xs" style="color:var(--theme-text); opacity:0.6">累计替换</div>
          </div>
          <div class="p-3 rounded-xl" style="background:rgba(245,230,200,0.3)">
            <div class="text-2xl font-title" style="color:#D4A85A" id="md-streak">0</div>
            <div class="text-xs" style="color:var(--theme-text); opacity:0.6">连续天数</div>
          </div>
        </div>

        <!-- 快速记录 -->
        <div class="mb-4">
          <div class="text-xs font-medium mb-2" style="color:var(--theme-text)">💭 快速记录一个负面想法</div>
          <div class="flex gap-2 mb-2 flex-wrap" id="md-quick-tags">
            <button class="chip-soft" onclick="quickMDDiet('我不够好')">我不够好</button>
            <button class="chip-soft" onclick="quickMDDiet('他不爱我')">他不爱我</button>
            <button class="chip-soft" onclick="quickMDDiet('我赚不到钱')">我赚不到钱</button>
            <button class="chip-soft" onclick="quickMDDiet('我做不到')">我做不到</button>
            <button class="chip-soft" onclick="quickMDDiet('我很焦虑')">我很焦虑</button>
            <button class="chip-soft" onclick="quickMDDiet('没人在乎我')">没人在乎我</button>
          </div>
          <div class="flex gap-2">
            <input type="text" id="md-input" placeholder="或者自己写一个..." class="dream-input text-sm flex-1 !p-2"/>
            <button onclick="addMDDiet()" class="soft-btn btn-primary px-4 text-sm">替换 ✨</button>
          </div>
        </div>

        <!-- 替换结果 -->
        <div id="md-result" class="hidden mb-4">
          <div class="p-3 rounded-xl mb-2" style="background:rgba(245,213,213,0.2); text-decoration: line-through; opacity:0.6">
            <div class="text-[10px] mb-0.5" style="color:var(--theme-text); opacity:0.5">⚫ 负面想法</div>
            <div class="text-sm" style="color:var(--theme-text)" id="md-neg-text"></div>
          </div>
          <div class="text-center text-xs mb-2" style="color:var(--theme-text); opacity:0.4">⬇ 替换为 ⬇</div>
          <div class="p-3 rounded-xl" style="background:linear-gradient(135deg, rgba(245,230,200,0.3), rgba(212,181,199,0.2))">
            <div class="text-[10px] mb-0.5" style="color:var(--theme-text); opacity:0.6">💛 正面肯定语</div>
            <div class="text-sm font-medium" style="color:var(--theme-text)" id="md-pos-text"></div>
          </div>
        </div>

        <!-- 21天日历 -->
        <div class="grid grid-cols-7 gap-1.5 mb-3" id="md-calendar"></div>
        <p class="text-[10px] text-center" style="color:var(--theme-text); opacity:0.4">断签不清零，慢慢来没关系 💖</p>
      </div>

      <!-- 情绪调频 -->
      <div class="glass-card p-5 mb-5">
        <h3 class="font-title text-base mb-3 flex items-center gap-2" style="color:var(--theme-text)">
          <span>🌈</span> 情绪调频阶梯
        </h3>
        <p class="text-xs mb-4" style="color:var(--theme-text); opacity:0.6">不用逼自己立刻开心，一步一步往上走就好 🌸</p>

        <div class="mb-4">
          <div class="flex justify-between text-xs mb-2">
            <span style="color:var(--theme-text); opacity:0.6">你当前的情绪位置</span>
            <span class="font-medium" style="color:var(--theme-text)" id="emotion-level-text">点击选择</span>
          </div>
          <div class="emotion-scale">
            <div class="emotion-marker" id="emotion-marker" style="left:50%"></div>
          </div>
          <div class="flex justify-between text-[10px] mt-1" style="color:var(--theme-text); opacity:0.4">
            <span>悲伤</span>
            <span>愤怒</span>
            <span>平静</span>
            <span>希望</span>
            <span>喜悦</span>
          </div>
        </div>

        <div class="grid grid-cols-5 gap-1.5 mb-4" id="emotion-selector">
          <button class="p-2 rounded-lg transition text-center" style="background:rgba(184,169,201,0.1)" onclick="setEmotionLevel(5)">
            <div class="text-lg">😢</div>
            <div class="text-[9px]" style="color:var(--theme-text); opacity:0.6">悲伤</div>
          </button>
          <button class="p-2 rounded-lg transition text-center" style="background:rgba(245,213,213,0.3)" onclick="setEmotionLevel(25)">
            <div class="text-lg">😠</div>
            <div class="text-[9px]" style="color:var(--theme-text); opacity:0.6">愤怒</div>
          </button>
          <button class="p-2 rounded-lg transition text-center" style="background:rgba(245,230,200,0.3)" onclick="setEmotionLevel(50)">
            <div class="text-lg">😐</div>
            <div class="text-[9px]" style="color:var(--theme-text); opacity:0.6">平静</div>
          </button>
          <button class="p-2 rounded-lg transition text-center" style="background:rgba(136,200,152,0.2)" onclick="setEmotionLevel(75)">
            <div class="text-lg">😊</div>
            <div class="text-[9px]" style="color:var(--theme-text); opacity:0.6">希望</div>
          </button>
          <button class="p-2 rounded-lg transition text-center" style="background:rgba(184,169,201,0.2)" onclick="setEmotionLevel(95)">
            <div class="text-lg">🥰</div>
            <div class="text-[9px]" style="color:var(--theme-text); opacity:0.6">喜悦</div>
          </button>
        </div>

        <div id="emotion-guide" class="p-4 rounded-2xl" style="background:linear-gradient(135deg, rgba(240,213,224,0.15), rgba(184,169,201,0.1))">
          <div class="text-xs font-medium mb-2" style="color:var(--theme-text)">💡 下一步调频建议</div>
          <div class="text-xs" style="color:var(--theme-text); opacity:0.7">选择你当前的情绪，我来告诉你下一步怎么走～</div>
        </div>

        <div class="grid grid-cols-3 gap-2 mt-4">
          <button class="p-3 rounded-xl transition text-center card-hover" style="background:rgba(240,213,224,0.15)" onclick="doEmotionPractice('EFT敲击')">
            <div class="text-lg mb-0.5">👐</div>
            <div class="text-[10px]" style="color:var(--theme-text)">EFT敲击</div>
          </button>
          <button class="p-3 rounded-xl transition text-center card-hover" style="background:rgba(201,216,232,0.25)" onclick="doEmotionPractice('478呼吸')">
            <div class="text-lg mb-0.5">🌬️</div>
            <div class="text-[10px]" style="color:var(--theme-text)">478呼吸</div>
          </button>
          <button class="p-3 rounded-xl transition text-center card-hover" style="background:rgba(184,169,201,0.15)" onclick="doEmotionPractice('书写释放')">
            <div class="text-lg mb-0.5">✍️</div>
            <div class="text-[10px]" style="color:var(--theme-text)">书写释放</div>
          </button>
        </div>
      </div>

      <!-- 肯定语电台 -->
      <div class="glass-card p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-title text-base flex items-center gap-2" style="color:var(--theme-text)">
            <span>🎙️</span> 肯定语电台
          </h3>
          <button onclick="openAffirmModal()" class="text-xs" style="color:#B8A9C9">➕ 自定义</button>
        </div>

        <div class="flex gap-2 mb-3 overflow-x-auto pb-1">
          <button class="chip-soft active" onclick="switchAffirmCat('love', this)">💖 恋爱SP</button>
          <button class="chip-soft" onclick="switchAffirmCat('money', this)">💰 财富事业</button>
          <button class="chip-soft" onclick="switchAffirmCat('beauty', this)">✨ 美貌自信</button>
          <button class="chip-soft" onclick="switchAffirmCat('heal', this)">🧘 情绪疗愈</button>
          <button class="chip-soft" onclick="switchAffirmCat('self', this)">🌱 自我概念</button>
          <button class="chip-soft" onclick="switchAffirmCat('saved', this)">💖 我的收藏</button>
        </div>

        <div class="flex gap-2 mb-3 overflow-x-auto pb-1" id="affirm-subcats">
        </div>

        <p class="text-xs mb-3" style="color:var(--theme-text); opacity:0.5">💡 点击肯定语会弹出温柔提示气泡哦～</p>

        <div id="affirm-list" class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 max-h-80 overflow-y-auto pr-1">
        </div>
      </div>
    </section>

    <!-- ========== 页面6：灵感行动花田 ========== -->
    <section id="page-garden" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">🌸 灵感行动花田</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        第5步 · 行动落地<br/>
        <span class="text-xs">不是硬逼自己行动，而是记录灵感来临时你自然想做的小事 🌱</span>
      </p>

      <div class="grid lg:grid-cols-3 gap-5">
        <div class="lg:col-span-2 space-y-5">
          <div class="glass-card p-5">
            <h3 class="font-title text-base mb-2" style="color:var(--theme-text)">💡 今天冒出来的灵感小行动</h3>
            <p class="text-xs mb-4" style="color:var(--theme-text); opacity:0.6">突然想做什么就记下来——这是宇宙在给你指路哦 ✨</p>

            <div class="flex gap-2 mb-3">
              <select id="action-type" class="dream-input text-sm !py-2.5 flex-shrink-0 w-24">
                <option value="love">💖 恋爱</option>
                <option value="money">💰 搞钱</option>
                <option value="beauty">✨ 变美</option>
                <option value="heal">🧘 疗愈</option>
                <option value="study">📚 学习</option>
                <option value="life">🏠 生活</option>
              </select>
              <input type="text" id="action-text" placeholder="例：突然想改简历 / 想穿好看的裙子出门..." class="dream-input text-sm flex-1"/>
              <button onclick="addInspirationAction()" class="soft-btn btn-primary px-5 py-2.5 text-sm font-title shrink-0">
                种下
              </button>
            </div>

            <div class="text-xs mb-2" style="color:var(--theme-text); opacity:0.5">
              今日灵感行动：<span class="font-medium" style="color:var(--theme-text)" id="today-action-count">0</span> 个
            </div>

            <div id="action-list" class="space-y-2 max-h-48 overflow-y-auto pr-1">
              <div class="text-center py-5 text-sm" style="color:var(--theme-text); opacity:0.4">
                今天还没有灵感行动，慢慢来，灵感会来的 🌱
              </div>
            </div>
          </div>

          <div class="glass-card p-5">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-title text-base" style="color:var(--theme-text)">🌺 我的灵感花田</h3>
              <span class="text-xs" style="color:var(--theme-text); opacity:0.5">已种 <span class="font-medium" style="color:var(--theme-text)" id="flower-count">0</span> 朵</span>
            </div>
            <div class="flower-grid" id="flower-grid"></div>
            <p class="text-center text-xs mt-3" style="color:var(--theme-text); opacity:0.4">
              每完成一个灵感行动，花田里就会开出一朵花 🌸
            </p>
          </div>

          <div class="glass-card p-5">
            <h3 class="font-title text-base mb-3" style="color:var(--theme-text)">🏆 小胜利记录</h3>
            <p class="text-xs mb-3" style="color:var(--theme-text); opacity:0.6">每一个小胜利都值得被看见，它们在重建你的自我效能感 💪</p>
            <div id="win-list" class="space-y-2 max-h-40 overflow-y-auto pr-1">
              <div class="text-center py-4 text-sm" style="color:var(--theme-text); opacity:0.4">
                完成第一个行动后，来记录你的感受吧～
              </div>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <div class="glass-card p-5">
            <h4 class="font-title text-sm mb-3" style="color:var(--theme-text)">📊 行动统计</h4>
            <div class="grid grid-cols-2 gap-2">
              <div class="p-3 rounded-xl text-center" style="background:rgba(240,213,224,0.15)">
                <div class="text-xl font-title" style="color:#D4A5B8" id="stat-love">0</div>
                <div class="text-xs" style="color:var(--theme-text); opacity:0.6">💖 恋爱花</div>
              </div>
              <div class="p-3 rounded-xl text-center" style="background:rgba(245,230,200,0.3)">
                <div class="text-xl font-title" style="color:#D4A85A" id="stat-money">0</div>
                <div class="text-xs" style="color:var(--theme-text); opacity:0.6">💰 财富花</div>
              </div>
              <div class="p-3 rounded-xl text-center" style="background:rgba(184,169,201,0.15)">
                <div class="text-xl font-title" style="color:#8B7E9C" id="stat-beauty">0</div>
                <div class="text-xs" style="color:var(--theme-text); opacity:0.6">✨ 美貌花</div>
              </div>
              <div class="p-3 rounded-xl text-center" style="background:rgba(136,200,152,0.2)">
                <div class="text-xl font-title" style="color:#5A9C6A" id="stat-heal">0</div>
                <div class="text-xs" style="color:var(--theme-text); opacity:0.6">🧘 疗愈花</div>
              </div>
            </div>
          </div>

          <div class="glass-card p-5" style="background:linear-gradient(145deg, rgba(240,213,224,0.2), rgba(184,169,201,0.1))">
            <h4 class="font-title text-sm mb-2" style="color:var(--theme-text)">💡 为什么是灵感行动？</h4>
            <p class="text-xs leading-relaxed" style="color:var(--theme-text); opacity:0.75">
              当你状态对齐时，宇宙会通过"灵感"给你传送行动指引。
              这些行动不是"我应该做"，而是"我好想做"。
              跟随灵感行动，就是走在显化的顺流里。
              不费力，却最有效 ✨
            </p>
          </div>

          <div class="glass-card p-5">
            <h4 class="font-title text-sm mb-3" style="color:var(--theme-text)">🏅 花仙徽章</h4>
            <div class="grid grid-cols-4 gap-2" id="garden-badges"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 页面7：显化日志馆 ========== -->
    <section id="page-diary" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">📔 显化日志馆</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        第6步 · 日常维持<br/>
        <span class="text-xs">写日记不是任务，是和自己温柔对话的时间 💕</span>
      </p>

      <div class="grid lg:grid-cols-3 gap-5">
        <div class="lg:col-span-2">
          <div class="glass-card p-5">
            <div class="flex gap-2 mb-3 overflow-x-auto pb-1">
              <button class="chip-soft active" onclick="selectDiaryTemplate('gratitude', this)">🙏 感恩日记</button>
              <button class="chip-soft" onclick="selectDiaryTemplate('future', this)">🔮 未来日记</button>
              <button class="chip-soft" onclick="selectDiaryTemplate('success', this)">🎉 星愿成真日志</button>
            </div>

            <div class="flex gap-2 mb-3 items-center">
              <span class="text-xs shrink-0" style="color:var(--theme-text); opacity:0.5">信纸：</span>
              <button class="shrink-0 w-8 h-8 rounded-lg border-2 transition paper-skin-btn active" style="border-color:#D4B5C7; background:linear-gradient(135deg, #FDF2F8, #FCE7F3)" onclick="selectPaperSkin('sakura', this)" title="樱花"></button>
              <button class="shrink-0 w-8 h-8 rounded-lg border-2 border-transparent transition paper-skin-btn" style="background:linear-gradient(135deg, #EEF2FF, #E0E7FF)" onclick="selectPaperSkin('star', this)" title="星空"></button>
              <button class="shrink-0 w-8 h-8 rounded-lg border-2 border-transparent transition paper-skin-btn" style="background:linear-gradient(135deg, #FFF1F2, #FECDD3)" onclick="selectPaperSkin('rose', this)" title="玫瑰"></button>
              <button class="shrink-0 w-8 h-8 rounded-lg border-2 border-transparent transition paper-skin-btn" style="background:linear-gradient(135deg, #F0FDF4, #BBF7D0)" onclick="selectPaperSkin('lily', this)" title="铃兰"></button>
              <button class="shrink-0 w-8 h-8 rounded-lg border-2 border-transparent transition paper-skin-btn" style="background:linear-gradient(135deg, #EFF6FF, #DBEAFE)" onclick="selectPaperSkin('cloud', this)" title="云朵"></button>
            </div>

            <div id="diary-paper" class="letter-paper p-5 min-h-[300px] relative" style="background:linear-gradient(180deg, #FFFEFF, #FDF2F8)">
              <div class="flex items-center justify-between mb-3">
                <input type="text" id="diary-date" placeholder="日期（例：2026年10月1日）"
                  class="bg-transparent border-b border-dashed focus:outline-none text-sm w-40" style="border-color:rgba(184,169,201,0.3); color:var(--theme-text)"/>
                <span class="text-xs" style="color:var(--theme-text); opacity:0.4" id="diary-template-label">感恩日记</span>
              </div>
              <textarea id="diary-content" placeholder="今天想写点什么呢..." rows="10"
                class="w-full bg-transparent border-none outline-none text-sm resize-none leading-7"
                style="color:var(--theme-text); font-family:inherit"
                oninput="playTypeSound()"></textarea>
            </div>

            <div class="flex gap-2 mt-4">
              <button onclick="saveDiary()" class="soft-btn btn-primary flex-1 py-3 text-sm font-title">
                💌 保存日记
              </button>
              <button onclick="showDiaryHistory()" class="soft-btn btn-soft px-5 py-3 text-sm">
                📚 历史
              </button>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <div class="glass-card p-5">
            <h4 class="font-title text-sm mb-3" style="color:var(--theme-text)">📝 三种日记怎么写？</h4>
            <div class="space-y-3 text-xs">
              <div class="p-3 rounded-xl" style="background:rgba(240,213,224,0.15)">
                <div class="font-medium mb-1" style="color:#B8859C">🙏 感恩日记</div>
                <p style="color:var(--theme-text); opacity:0.7">每天写3件值得感恩的小事，培养丰盛感。哪怕是"今天天气很好"也可以。</p>
              </div>
              <div class="p-3 rounded-xl" style="background:rgba(184,169,201,0.12)">
                <div class="font-medium mb-1" style="color:#8B7E9C">🔮 未来日记</div>
                <p style="color:var(--theme-text); opacity:0.7">以"愿望已经实现的你"的身份写今天发生的事。用现在时，越细节越好。</p>
              </div>
              <div class="p-3 rounded-xl" style="background:rgba(245,230,200,0.3)">
                <div class="font-medium mb-1" style="color:#B8955A">🎉 星愿成真日志</div>
                <p style="color:var(--theme-text); opacity:0.7">记录所有大小显化，积累"我总能星愿成真"的证据。小事也算！</p>
              </div>
            </div>
          </div>

          <div class="glass-card p-5">
            <h4 class="font-title text-sm mb-2" style="color:var(--theme-text)">📊 日记统计</h4>
            <div class="grid grid-cols-2 gap-2 text-center">
              <div class="p-3 rounded-xl" style="background:rgba(240,213,224,0.15)">
                <div class="text-xl font-title" style="color:#D4A5B8" id="diary-total">0</div>
                <div class="text-xs" style="color:var(--theme-text); opacity:0.6">总篇数</div>
              </div>
              <div class="p-3 rounded-xl" style="background:rgba(184,169,201,0.15)">
                <div class="text-xl font-title" style="color:#8B7E9C" id="diary-streak">0</div>
                <div class="text-xs" style="color:var(--theme-text); opacity:0.6">连续天数</div>
              </div>
            </div>
          </div>

          <div class="glass-card p-5" style="background:linear-gradient(145deg, rgba(245,230,200,0.2), rgba(240,213,224,0.1))">
            <h4 class="font-title text-sm mb-2" style="color:var(--theme-text)">💫 今日写作灵感</h4>
            <p class="text-xs leading-relaxed" style="color:var(--theme-text); opacity:0.75" id="diary-prompt">
              如果今天一切都很完美，你会怎么度过这一天？
            </p>
            <button onclick="newDiaryPrompt()" class="text-xs mt-2" style="color:#B8A9C9">🔄 换一个</button>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 页面8：宇宙智慧花园 ========== -->
    <section id="page-library" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">📚 宇宙智慧花园</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        第7步 · 知识库<br/>
        <span class="text-xs">学习显化的底层逻辑，知其然更知其所以然 📖</span>
      </p>

      <div class="flex gap-2 mb-5 overflow-x-auto pb-1">
        <button class="tab-pill whitespace-nowrap active" onclick="switchLibTab('course', this)">🎓 入门课</button>
        <button class="tab-pill whitespace-nowrap" onclick="switchLibTab('books', this)">📖 经典拆解</button>
        <button class="tab-pill whitespace-nowrap" onclick="switchLibTab('methods', this)">💡 方法大全</button>
        <button class="tab-pill whitespace-nowrap" onclick="switchLibTab('guide', this)">🎯 场景指南</button>
        <button class="tab-pill whitespace-nowrap" onclick="switchLibTab('plans', this)">📋 显化计划</button>
        <button class="tab-pill whitespace-nowrap" onclick="switchLibTab('media', this)">🎬 书影音</button>
      </div>

      <div id="lib-course" class="space-y-4">
        <div class="glass-card p-5">
          <h3 class="font-title text-lg mb-4" style="color:var(--theme-text)">🎓 显化入门7课</h3>
          <div class="space-y-3" id="course-list"></div>
        </div>
      </div>

      <div id="lib-books" class="hidden space-y-4">
        <div class="glass-card p-5">
          <h3 class="font-title text-lg mb-4" style="color:var(--theme-text)">📚 显化书库</h3>
          <p class="text-xs mb-4" style="color:var(--theme-text); opacity:0.6">帮你把厚厚的书拆成核心方法，不用自己啃啦 ✨</p>
          <div class="book-shelf overflow-x-auto pb-4 mb-3">
            <div id="bookshelf"></div>
          </div>
          <div class="shelf-board" style="height:10px; background:linear-gradient(180deg, #B8A9C9, #8B7E9C); border-radius:2px; box-shadow:0 4px 10px rgba(139,126,156,0.25)"></div>
        </div>
      </div>

      <div id="lib-methods" class="hidden space-y-4">
        <div class="glass-card p-5">
          <h3 class="font-title text-lg mb-4" style="color:var(--theme-text)">💡 显化方法大全</h3>
          <p class="text-xs mb-4" style="color:var(--theme-text); opacity:0.6">每个方法都有详细步骤，挑最适合你的练～</p>
          <div class="grid sm:grid-cols-2 gap-3" id="methods-list"></div>
        </div>
      </div>

      <div id="lib-guide" class="hidden space-y-4">
        <div class="glass-card p-5">
          <h3 class="font-title text-lg mb-4" style="color:var(--theme-text)">🎯 分场景显化指南</h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3" id="guide-list"></div>
        </div>
      </div>

      <div id="lib-plans" class="hidden space-y-4">
        <div class="glass-card p-5">
          <h3 class="font-title text-lg mb-4" style="color:var(--theme-text)">📋 显化计划清单</h3>
          <p class="text-xs mb-4" style="color:var(--theme-text); opacity:0.6">选一个计划，每天打卡，一步步实现你的愿望 🌸</p>
          <div class="grid sm:grid-cols-3 gap-3" id="lib-plans-list"></div>
        </div>
      </div>

      <div id="lib-media" class="hidden space-y-4">
        <div class="glass-card p-5">
          <h3 class="font-title text-lg mb-4" style="color:var(--theme-text)">🎬 书影音疗愈馆</h3>
          <div class="flex gap-2 mb-4">
            <button class="chip-soft active" onclick="switchMediaTab('movies', this)">🎬 电影</button>
            <button class="chip-soft" onclick="switchMediaTab('music', this)">🎵 音乐</button>
          </div>
          <div id="media-content"></div>
        </div>
      </div>
    </section>

    <!-- ========== 页面：心愿墙 ========== -->
    <section id="page-wishwall" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">🪧 心愿墙</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        把愿望写在木牌上，挂在心愿墙上<br/>
        <span class="text-xs">相信的力量，会让愿望慢慢实现 ✨</span>
      </p>

      <!-- 统计 -->
      <div class="grid grid-cols-3 gap-3 mb-5 text-center">
        <div class="glass-card p-4">
          <div class="text-2xl font-title" style="color:#D4A5B8" id="ww-total">0</div>
          <div class="text-xs" style="color:var(--theme-text); opacity:0.6">总愿望数</div>
        </div>
        <div class="glass-card p-4">
          <div class="text-2xl font-title" style="color:#E8C87A" id="ww-done">0</div>
          <div class="text-xs" style="color:var(--theme-text); opacity:0.6">已显化</div>
        </div>
        <div class="glass-card p-4">
          <div class="text-2xl font-title" style="color:#B8A9C9" id="ww-rate">0%</div>
          <div class="text-xs" style="color:var(--theme-text); opacity:0.6">显化率</div>
        </div>
      </div>

      <!-- 木牌墙 -->
      <div class="glass-card p-5 mb-5">
        <h3 class="font-title text-base mb-4 flex items-center justify-between" style="color:var(--theme-text)">
          <span>🪵 我的心愿木牌</span>
          <button onclick="openNewWishModal()" class="text-xs px-3 py-1.5 rounded-full font-title" style="background:linear-gradient(135deg, #D4A5B8, #B8859C); color:white">+ 新愿望</button>
        </h3>
        <div id="wishwall-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3">
          <div class="text-center py-8 text-sm col-span-full" style="color:var(--theme-text); opacity:0.4">
            还没有愿望木牌，写下第一个愿望吧 🌟
          </div>
        </div>
      </div>

      <!-- 愿望详情弹窗占位 -->
      <div id="wish-detail-modal" class="modal-backdrop">
        <div class="modal-content p-5 max-w-md">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display text-lg" style="color:var(--theme-text)" id="wd-title">愿望详情</h3>
            <button onclick="closeWishDetail()" class="text-lg" style="color:var(--theme-text); opacity:0.4">×</button>
          </div>
          <div id="wish-detail-content"></div>
        </div>
      </div>

      <!-- 添加习惯弹窗 -->
      <div id="habit-modal" class="modal-backdrop">
        <div class="modal-content p-5 max-w-md">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display text-lg" style="color:var(--theme-text)">添加显化习惯</h3>
            <button onclick="closeHabitModal()" class="text-lg" style="color:var(--theme-text); opacity:0.4">×</button>
          </div>
          <div class="space-y-3">
            <div>
              <label class="text-xs mb-1 block" style="color:var(--theme-text); opacity:0.6">习惯名称：</label>
              <input type="text" id="habit-name-input" placeholder="比如：每天读肯定语" class="dream-input text-sm"/>
            </div>
            <div>
              <label class="text-xs mb-1 block" style="color:var(--theme-text); opacity:0.6">选择分类：</label>
              <div class="flex gap-2 flex-wrap">
                <button class="chip-soft habit-cat-chip active" onclick="selectHabitCat('affirm', this)">💖 肯定语</button>
                <button class="chip-soft habit-cat-chip" onclick="selectHabitCat('meditation', this)">🧘 冥想</button>
                <button class="chip-soft habit-cat-chip" onclick="selectHabitCat('gratitude', this)">🙏 感恩</button>
                <button class="chip-soft habit-cat-chip" onclick="selectHabitCat('visualize', this)">✨ 视觉化</button>
                <button class="chip-soft habit-cat-chip" onclick="selectHabitCat('journal', this)">📔 写日记</button>
                <button class="chip-soft habit-cat-chip" onclick="selectHabitCat('other', this)">🌸 其他</button>
              </div>
            </div>
            <div>
              <label class="text-xs mb-1 block" style="color:var(--theme-text); opacity:0.6">重复频率：</label>
              <div class="flex gap-2 flex-wrap">
                <button class="chip-soft habit-freq-chip active" onclick="selectHabitFreq('daily', this)">每天</button>
                <button class="chip-soft habit-freq-chip" onclick="selectHabitFreq('custom', this)">自定义</button>
              </div>
            </div>
            <div id="habit-weekdays" class="hidden">
              <label class="text-xs mb-1 block" style="color:var(--theme-text); opacity:0.6">选择星期：</label>
              <div class="flex gap-1.5">
                ${['日','一','二','三','四','五','六'].map((d,i) => `
                  <button class="w-8 h-8 rounded-full text-xs habit-weekday-btn" onclick="toggleHabitWeekday(${i}, this)" style="background:rgba(184,169,201,0.1); color:var(--theme-text)">${d}</button>
                `).join('')}
              </div>
            </div>
            <div>
              <label class="text-xs mb-1 block" style="color:var(--theme-text); opacity:0.6">提醒时间（可选）：</label>
              <input type="time" id="habit-reminder-input" class="dream-input text-sm"/>
            </div>
            <button onclick="addHabit()" class="soft-btn btn-primary w-full py-3 font-title">
              ✨ 添加习惯
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 页面9：我的星空 ========== -->
    <section id="page-sky" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">🌌 我的星空</h2>
      </div>

      <div class="grid lg:grid-cols-3 gap-5">
        <div class="lg:col-span-2 space-y-5">
          <!-- 专属星空 -->
          <div class="glass-card p-5">
            <h3 class="font-title text-base mb-3" style="color:var(--theme-text)">⭐ 你的专属星空</h3>
            <div class="starry-sky relative" style="min-height: 280px" id="personal-sky">
              <div class="absolute inset-0 flex items-center justify-center text-white/40 text-sm">
                许的愿望越多，星空越灿烂 ✨
              </div>
            </div>
            <div class="flex justify-around mt-3 text-xs" style="color:var(--theme-text); opacity:0.6">
              <span>总愿望：<span class="font-medium" style="color:var(--theme-text)" id="sky-total">0</span></span>
              <span>已显化：<span class="font-medium text-amber-500" id="sky-done">0</span></span>
            </div>
           </div>

          <!-- 习惯打卡 -->
          <div class="glass-card p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-title text-base" style="color:var(--theme-text)">✅ 显化习惯打卡</h3>
              <button onclick="openHabitModal()" class="text-xs" style="color:var(--theme-text); opacity:0.6">+ 添加习惯</button>
            </div>
            <div id="habit-list" class="space-y-2.5">
              <div class="text-center py-6 text-sm" style="color:var(--theme-text); opacity:0.4">
                还没有习惯，添加第一个显化习惯吧 🌱
              </div>
            </div>
            <!-- 打卡日历 -->
            <div id="habit-calendar-section" class="hidden mt-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs" style="color:var(--theme-text); opacity:0.6" id="habit-cal-title">本月打卡</span>
                <div class="flex gap-1">
                  <button onclick="prevHabitMonth()" class="text-xs px-2 py-0.5 rounded" style="background:rgba(184,169,201,0.1); color:var(--theme-text)">←</button>
                  <button onclick="nextHabitMonth()" class="text-xs px-2 py-0.5 rounded" style="background:rgba(184,169,201,0.1); color:var(--theme-text)">→</button>
                </div>
              </div>
              <div class="grid grid-cols-7 gap-1 text-center text-[10px] mb-1" style="color:var(--theme-text); opacity:0.4">
                <span>日</span><span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span>
              </div>
              <div id="habit-calendar" class="grid grid-cols-7 gap-1"></div>
            </div>
          </div>

          <!-- 显化进度 -->
          <div class="glass-card p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-title text-base" style="color:var(--theme-text)">📊 显化进度</h3>
              <button onclick="openGrowthPage()" class="text-xs" style="color:var(--theme-text); opacity:0.6">成长数据 →</button>
            </div>
            <div class="space-y-4">
              <div>
                <div class="flex justify-between text-sm mb-1.5">
                  <span style="color:var(--theme-text)">🔮 信念清理</span>
                  <span style="color:var(--theme-text); opacity:0.5" id="progress-belief">0%</span>
                </div>
                <div class="progress-bar">
                  <div class="progress-fill" style="background:linear-gradient(90deg, #B8A9C9, #D4B5C7)" id="progress-bar-belief" style="width:0%"></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-sm mb-1.5">
                  <span style="color:var(--theme-text)">⭐ 愿景清晰度</span>
                  <span style="color:var(--theme-text); opacity:0.5" id="progress-vision">0%</span>
                </div>
                <div class="progress-bar">
                  <div class="progress-fill" style="background:linear-gradient(90deg, #E8C87A, #F5E6C8)" id="progress-bar-vision" style="width:0%"></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-sm mb-1.5">
                  <span style="color:var(--theme-text)">☁️ 状态对齐</span>
                  <span style="color:var(--theme-text); opacity:0.5" id="progress-state">0%</span>
                </div>
                <div class="progress-bar">
                  <div class="progress-fill" style="background:linear-gradient(90deg, #9DB5C8, #C9D8E8)" id="progress-bar-state" style="width:0%"></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-sm mb-1.5">
                  <span style="color:var(--theme-text)">🌸 行动落地</span>
                  <span style="color:var(--theme-text); opacity:0.5" id="progress-action">0%</span>
                </div>
                <div class="progress-bar">
                  <div class="progress-fill" style="background:linear-gradient(90deg, #88C898, #B8E0C0)" id="progress-bar-action" style="width:0%"></div>
                </div>
              </div>
            </div>
            <div class="mt-4 p-4 rounded-2xl" style="background:linear-gradient(135deg, rgba(240,213,224,0.15), rgba(184,169,201,0.1))">
              <div class="text-xs font-medium mb-1" style="color:var(--theme-text)">💡 下一步建议</div>
              <div class="text-xs" style="color:var(--theme-text); opacity:0.75" id="next-step-suggestion">
                从星光水晶测试神殿开始，了解你的星愿起点吧～
              </div>
            </div>
          </div>

          <!-- 我的花田 -->
          <div class="glass-card p-5">
            <h3 class="font-title text-base mb-3" style="color:var(--theme-text)">🌸 我的灵感花田</h3>
            <div class="flower-grid" id="palace-flower-grid"></div>
            <p class="text-center text-xs mt-3" style="color:var(--theme-text); opacity:0.4">
              每一朵花都是你走在显化路上的证据 🌺
            </p>
          </div>
        </div>

        <div class="space-y-4">
          <!-- 个人信息 -->
          <div class="glass-card p-5 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-28 h-28 rounded-bl-full" style="background:linear-gradient(135deg, rgba(240,213,224,0.3), transparent)"></div>
            <div class="flex items-center gap-4 mb-4 relative">
              <div id="palace-avatar" class="w-16 h-16 rounded-full flex items-center justify-center text-3xl shrink-0 shadow-soft animate-breath overflow-hidden border-3" style="background:linear-gradient(135deg, #F5E1EA, #D4B5C7, #B8A9C9); border:3px solid white">
                🌸
              </div>
              <div class="min-w-0 flex-1">
                <input type="text" id="palace-nickname" value="小公主"
                  class="bg-transparent border-b-2 border-dashed focus:outline-none w-full font-display text-lg"
                  style="border-color:rgba(212,181,199,0.4); color:var(--theme-text)"
                  onchange="updateNickname(this.value)"/>
                <div class="flex items-center gap-2 mt-1">
                  <span class="level-badge" id="palace-level">新手</span>
                  <span class="text-xs" style="color:var(--theme-text); opacity:0.5" id="palace-persona-name">待解锁</span>
                </div>
              </div>
            </div>
            <div class="grid grid-cols-4 gap-1.5">
              <div class="text-center p-2 rounded-lg" style="background:rgba(245,213,213,0.2)">
                <div class="text-base font-title" style="color:#D4A5B8" id="palace-energy">0</div>
                <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">💎 能量</div>
              </div>
              <div class="text-center p-2 rounded-lg" style="background:rgba(184,169,201,0.15)">
                <div class="text-base font-title" style="color:#8B7E9C" id="palace-wishes">0</div>
                <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">⭐ 愿望</div>
              </div>
              <div class="text-center p-2 rounded-lg" style="background:rgba(136,200,152,0.2)">
                <div class="text-base font-title" style="color:#5A9C6A" id="palace-flowers">0</div>
                <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">🌸 花</div>
              </div>
              <div class="text-center p-2 rounded-lg" style="background:rgba(245,230,200,0.3)">
                <div class="text-base font-title" style="color:#D4A85A" id="palace-badges">0</div>
                <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">🏅 徽章</div>
              </div>
            </div>
          </div>

          <!-- 公主身份 -->
          <div class="glass-card p-5">
            <h4 class="font-title text-sm mb-3" style="color:var(--theme-text)">👑 我的公主身份</h4>
            <div id="palace-persona-card" class="text-center py-6 text-sm" style="color:var(--theme-text); opacity:0.4">
              完成星光水晶测试，解锁你的专属公主身份 ✨
            </div>
          </div>

          <!-- 治愈卡册 -->
          <div class="glass-card p-5">
            <div class="flex items-center justify-between mb-3">
              <h4 class="font-title text-sm" style="color:var(--theme-text)">🎴 治愈卡片册</h4>
              <span class="text-xs" style="color:var(--theme-text); opacity:0.5"><span id="card-count">0</span>/${HEALING_CARDS.length}</span>
            </div>
            <div id="card-collection" class="grid grid-cols-3 gap-2"></div>
          </div>

          <!-- 徽章墙 -->
          <div class="glass-card p-5">
            <h4 class="font-title text-sm mb-3" style="color:var(--theme-text)">🏆 徽章收集墙</h4>
            <div id="palace-badges-wall" class="grid grid-cols-4 gap-2"></div>
          </div>

          <!-- 肯定语库 -->
          <div class="glass-card p-5">
            <h4 class="font-title text-sm mb-3" style="color:var(--theme-text)">💖 我的肯定语</h4>
            <div id="palace-affirmations" class="space-y-2 max-h-48 overflow-y-auto">
              <div class="text-center py-5 text-sm" style="color:var(--theme-text); opacity:0.4">
                收藏喜欢的肯定语，随时听～
              </div>
            </div>
          </div>

          <!-- 设置入口 -->
          <button onclick="openSettings()" class="glass-card p-4 w-full text-left card-hover">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center text-lg" style="background:rgba(184,169,201,0.15)">⚙️</div>
              <div class="flex-1">
                <div class="text-sm font-medium" style="color:var(--theme-text)">设置</div>
                <div class="text-xs" style="color:var(--theme-text); opacity:0.5">声音 · 主题 · 隐私 · 数据</div>
              </div>
              <span style="color:var(--theme-text); opacity:0.3">→</span>
            </div>
          </button>
        </div>
      </div>
    </section>

    <!-- ========== 页面10：成长数据 ========== -->
    <section id="page-growth" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="switchTab('journal')" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">📈 成长数据</h2>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
        <div class="glass-card p-4 text-center">
          <div class="text-2xl font-title mb-1" style="color:#D4A5B8" id="growth-days">1</div>
          <div class="text-xs" style="color:var(--theme-text); opacity:0.6">显化天数</div>
        </div>
        <div class="glass-card p-4 text-center">
          <div class="text-2xl font-title mb-1" style="color:#8B7E9C" id="growth-wishes">0</div>
          <div class="text-xs" style="color:var(--theme-text); opacity:0.6">许下愿望</div>
        </div>
        <div class="glass-card p-4 text-center">
          <div class="text-2xl font-title mb-1" style="color:#E8C87A" id="growth-manifested">0</div>
          <div class="text-xs" style="color:var(--theme-text); opacity:0.6">已显化</div>
        </div>
        <div class="glass-card p-4 text-center">
          <div class="text-2xl font-title mb-1" style="color:#88C898" id="growth-purify">0</div>
          <div class="text-xs" style="color:var(--theme-text); opacity:0.6">清理信念</div>
        </div>
      </div>

      <div class="glass-card p-5 mb-5">
        <h3 class="font-title text-base mb-4" style="color:var(--theme-text)">📊 显化进度曲线</h3>
        <div class="chart-container">
          <canvas id="progress-chart" height="180"></canvas>
        </div>
      </div>

       <div class="grid md:grid-cols-2 gap-5 mb-5">
         <div class="glass-card p-5">
           <h3 class="font-title text-base mb-4" style="color:var(--theme-text)">🌈 情绪变化趋势</h3>
           <div class="chart-container">
             <canvas id="emotion-chart" height="160"></canvas>
           </div>
         </div>
         <div class="glass-card p-5">
           <h3 class="font-title text-base mb-4" style="color:var(--theme-text)">🌸 行动类型分布</h3>
           <div class="chart-container">
             <canvas id="action-chart" height="160"></canvas>
           </div>
         </div>
       </div>

       <!-- 情绪报告 -->
       <div class="glass-card p-5 mb-5">
         <div class="flex items-center justify-between mb-4">
           <h3 class="font-title text-base" style="color:var(--theme-text)">💌 情绪报告</h3>
           <div class="flex gap-1">
             <button class="chip-soft active" id="report-week-btn" onclick="switchMoodReport('week', this)">本周</button>
             <button class="chip-soft" id="report-month-btn" onclick="switchMoodReport('month', this)">本月</button>
           </div>
         </div>
         <div id="mood-report-content">
           <div class="text-center py-6 text-sm" style="color:var(--theme-text); opacity:0.4">
             还没有情绪花园，去首页记录一下吧～
           </div>
         </div>
       </div>

      <div class="glass-card p-5">
        <h3 class="font-title text-base mb-4" style="color:var(--theme-text)">🏆 成就里程碑</h3>
        <div class="space-y-3">
          <div class="flex items-center gap-3 p-3 rounded-xl" style="background:rgba(240,213,224,0.15)">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg shrink-0" style="background:linear-gradient(135deg, #F5E6C8, #E8C87A)">🎯</div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium" style="color:var(--theme-text)">第一次星愿成真</div>
              <div class="text-xs" style="color:var(--theme-text); opacity:0.5">完成第一个愿望的显化</div>
            </div>
            <span class="text-xs" id="milestone-1" style="color:var(--theme-text); opacity:0.4">未达成</span>
          </div>
          <div class="flex items-center gap-3 p-3 rounded-xl" style="background:rgba(184,169,201,0.12)">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg shrink-0" style="background:linear-gradient(135deg, #D4C5E0, #B8A9C9)">💎</div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium" style="color:var(--theme-text)">信念净化师</div>
              <div class="text-xs" style="color:var(--theme-text); opacity:0.5">连续21天信念清理</div>
            </div>
            <span class="text-xs" id="milestone-2" style="color:var(--theme-text); opacity:0.4">未达成</span>
          </div>
          <div class="flex items-center gap-3 p-3 rounded-xl" style="background:rgba(136,200,152,0.2)">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg shrink-0" style="background:linear-gradient(135deg, #B8E0C0, #88C898)">🌸</div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium" style="color:var(--theme-text)">花仙子</div>
              <div class="text-xs" style="color:var(--theme-text); opacity:0.5">种出50朵灵感花</div>
            </div>
            <span class="text-xs" id="milestone-3" style="color:var(--theme-text); opacity:0.4">未达成</span>
          </div>
          <div class="flex items-center gap-3 p-3 rounded-xl" style="background:rgba(245,230,200,0.3)">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg shrink-0" style="background:linear-gradient(135deg, #F5E6C8, #E8C87A)">📚</div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium" style="color:var(--theme-text)">显化毕业生</div>
              <div class="text-xs" style="color:var(--theme-text); opacity:0.5">学完显化入门7课</div>
            </div>
            <span class="text-xs" id="milestone-4" style="color:var(--theme-text); opacity:0.4">未达成</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 页面：星辰塔罗小屋 ========== -->
    <section id="page-tarot" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">🃏 星辰塔罗小屋</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        抽一张牌，听听宇宙想对你说什么 ✨<br/>
        <span class="text-xs">静下心来，想着你的问题，再抽牌哦～</span>
      </p>

      <!-- 牌阵选择 -->
      <div class="flex justify-center gap-2 mb-5">
        <button onclick="selectTarotSpread('single')" id="spread-single" class="px-4 py-2 rounded-full text-xs font-medium transition" style="background:linear-gradient(135deg, #D4B5C7, #B8A9C9); color:white">🎴 单牌指引</button>
        <button onclick="selectTarotSpread('three')" id="spread-three" class="px-4 py-2 rounded-full text-xs font-medium transition" style="background:rgba(184,169,201,0.1); color:var(--theme-text)">🃏🃏🃏 三牌阵</button>
      </div>

      <!-- 问题类型选择 -->
      <div class="glass-card p-4 mb-5">
        <div class="text-xs font-medium mb-3" style="color:var(--theme-text)">💭 你想问什么？</div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2" id="tarot-cats">
          <button onclick="selectTarotCat('love')" class="tarot-cat p-3 rounded-xl text-center text-xs transition" style="background:rgba(240,213,224,0.2); color:var(--theme-text)">
            <div class="text-xl mb-1">💖</div>感情
          </button>
          <button onclick="selectTarotCat('career')" class="tarot-cat p-3 rounded-xl text-center text-xs transition" style="background:rgba(245,230,200,0.3); color:var(--theme-text)">
            <div class="text-xl mb-1">💼</div>事业
          </button>
          <button onclick="selectTarotCat('emotion')" class="tarot-cat p-3 rounded-xl text-center text-xs transition" style="background:rgba(221,235,224,0.3); color:var(--theme-text)">
            <div class="text-xl mb-1">🧘</div>情绪
          </button>
          <button onclick="selectTarotCat('guide')" class="tarot-cat p-3 rounded-xl text-center text-xs transition" style="background:rgba(184,169,201,0.15); color:var(--theme-text)">
            <div class="text-xl mb-1">🌟</div>今日指引
          </button>
        </div>
      </div>

      <!-- 抽牌区 -->
      <div class="glass-card p-5 mb-5 text-center" id="tarot-draw-area">
        <div class="mb-4" id="tarot-cards-container">
          <div class="w-32 h-44 mx-auto rounded-xl flex items-center justify-center text-4xl cursor-pointer card-hover transition-transform hover:scale-105"
            onclick="drawTarot()"
            style="background:linear-gradient(135deg, #5D4E6D, #3D3258); box-shadow:0 10px 30px rgba(93,78,109,0.4); border:2px solid #B8A9C9;">
            ✨
          </div>
        </div>
        <p class="text-xs mb-3" style="color:var(--theme-text); opacity:0.6" id="tarot-draw-hint">点击牌背抽一张牌</p>
        <button onclick="drawTarot()" class="soft-btn btn-primary px-8 py-2.5 text-sm font-title">
          🎴 抽牌
        </button>
      </div>

      <!-- 结果区（默认隐藏） -->
      <div id="tarot-result" class="hidden">
        <div id="tarot-single-result">
          <div class="glass-card p-5 mb-5">
            <div class="text-center mb-4">
              <div id="tarot-card-name" class="font-display text-xl mb-1" style="color:var(--theme-text)"></div>
              <div id="tarot-card-pos" class="text-xs" style="color:#B8A9C9"></div>
            </div>
            <div class="w-32 h-44 mx-auto mb-4 rounded-xl flex items-center justify-center text-5xl"
              id="tarot-card-front"
              style="background:linear-gradient(135deg, #F5E1EA, #E8DEEF); box-shadow:0 8px 24px rgba(184,169,201,0.3); border:2px solid #D4B5C7;">
            </div>
            <div class="space-y-3 text-xs" style="color:var(--theme-text); opacity:0.8">
              <div>
                <div class="font-medium mb-1" style="color:var(--theme-text)">📖 牌意解读</div>
                <div id="tarot-meaning" class="leading-relaxed"></div>
              </div>
              <div>
                <div class="font-medium mb-1" style="color:var(--theme-text)">💫 给你的小建议</div>
                <div id="tarot-advice" class="leading-relaxed"></div>
              </div>
            </div>
          </div>
        </div>

        <div id="tarot-three-result" class="hidden">
          <div class="glass-card p-5 mb-5">
            <div class="text-center mb-4">
              <div class="font-display text-lg mb-1" style="color:var(--theme-text)">过去 · 现在 · 未来</div>
              <div class="text-xs" style="color:var(--theme-text); opacity:0.5">三牌阵解读</div>
            </div>
            <div class="flex justify-center gap-2 mb-5" id="three-cards-display"></div>
            <div class="space-y-4 text-xs" id="three-cards-detail" style="color:var(--theme-text); opacity:0.8"></div>
          </div>
        </div>

        <div class="flex gap-2">
          <button onclick="resetTarot()" class="soft-btn btn-soft flex-1 py-3 text-sm font-title">再抽一次</button>
          <button onclick="goHome()" class="soft-btn btn-primary flex-1 py-3 text-sm font-title">返回岛屿</button>
        </div>
      </div>
    </section>

    <!-- ========== 页面：显化计划 ========== -->
    <section id="page-plans" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">📋 显化计划清单</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        选一个计划，每天打卡，一步步实现你的愿望 🌸<br/>
        <span class="text-xs">慢慢来，坚持比完美更重要</span>
      </p>

      <!-- 计划选择 -->
      <div class="grid sm:grid-cols-3 gap-4 mb-6">
        <div class="glass-card p-4 card-hover cursor-pointer" onclick="selectPlan('beginner')">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-3" style="background:linear-gradient(135deg, #F5E1EA, #D4B5C7)">🌱</div>
          <h3 class="font-title text-base mb-1" style="color:var(--theme-text)">21天新手计划</h3>
          <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.6">从清理信念到许愿到行动，循序渐进</p>
          <div class="text-[10px]" style="color:#B8A9C9">适合刚接触显化的你 ✨</div>
        </div>
        <div class="glass-card p-4 card-hover cursor-pointer" onclick="selectPlan('sp')">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-3" style="background:linear-gradient(135deg, #F0D5E0, #D4A5B8)">💖</div>
          <h3 class="font-title text-base mb-1" style="color:var(--theme-text)">7天SP恋爱计划</h3>
          <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.6">针对想显化特定的人的7天练习</p>
          <div class="text-[10px]" style="color:#B87590">适合想显化SP的你 💗</div>
        </div>
        <div class="glass-card p-4 card-hover cursor-pointer" onclick="selectPlan('money')">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-3" style="background:linear-gradient(135deg, #F5E6C8, #E8C87A)">💰</div>
          <h3 class="font-title text-base mb-1" style="color:var(--theme-text)">14天财富计划</h3>
          <p class="text-xs mb-2" style="color:var(--theme-text); opacity:0.6">针对搞钱的14天练习</p>
          <div class="text-[10px]" style="color:#B8955A">适合想搞钱的你 💎</div>
        </div>
      </div>

      <!-- 计划详情（默认隐藏） -->
      <div id="plan-detail" class="hidden">
        <div class="glass-card p-4 mb-4">
          <div class="flex items-center justify-between mb-3">
            <h3 class="font-title text-base" style="color:var(--theme-text)" id="plan-title">21天新手计划</h3>
            <button onclick="closePlan()" class="text-xs" style="color:var(--theme-text); opacity:0.5">← 返回列表</button>
          </div>
          <div class="mb-3">
            <p class="text-xs leading-relaxed mb-3" style="color:var(--theme-text); opacity:0.7" id="plan-intro"></p>
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-xs" style="color:var(--theme-text); opacity:0.6">完成进度</span>
              <span class="text-xs font-medium" style="color:#B8A9C9"><span id="plan-done-count">0</span> / <span id="plan-total-count">21</span> 天</span>
            </div>
            <div class="w-full h-2.5 rounded-full overflow-hidden" style="background:rgba(184,169,201,0.12)">
              <div class="h-full progress-fill rounded-full" id="plan-progress-bar" style="background:linear-gradient(90deg, #D4B5C7, #B8A9C9); width:0%"></div>
            </div>
          </div>
          <p class="text-[10px]" style="color:var(--theme-text); opacity:0.5">💡 按顺序完成，每天1个小任务就好</p>
        </div>

        <div class="space-y-2" id="plan-tasks"></div>
      </div>
    </section>

    <!-- ========== 页面：专注计时器 ========== -->
    <section id="page-timer" class="page">
      <div class="flex items-center gap-3 mb-5">
        <button onclick="goHome()" class="soft-btn btn-soft w-10 h-10 flex items-center justify-center text-lg">←</button>
        <h2 class="font-display text-xl sm:text-2xl" style="color:var(--theme-text)">⏱️ 专注计时器</h2>
      </div>

      <p class="text-sm mb-5 text-center" style="color:var(--theme-text); opacity:0.6">
        选一个主题，专注一段时间，温柔地和自己在一起 🧘<br/>
        <span class="text-xs">结束会有温柔的提示音哦</span>
      </p>

      <!-- 主题选择 -->
      <div class="glass-card p-4 mb-5">
        <div class="text-xs font-medium mb-3" style="color:var(--theme-text)">🌸 你想做什么？</div>
        <div class="grid grid-cols-3 gap-2" id="timer-modes">
          <button onclick="selectTimerMode('meditation')" class="timer-mode p-3 rounded-xl text-center text-xs transition" style="background:rgba(221,235,224,0.3); color:var(--theme-text)">
            <div class="text-xl mb-1">🧘</div>冥想
          </button>
          <button onclick="selectTimerMode('study')" class="timer-mode p-3 rounded-xl text-center text-xs transition" style="background:rgba(201,216,232,0.3); color:var(--theme-text)">
            <div class="text-xl mb-1">📚</div>学习
          </button>
          <button onclick="selectTimerMode('affirm')" class="timer-mode p-3 rounded-xl text-center text-xs transition" style="background:rgba(240,213,224,0.2); color:var(--theme-text)">
            <div class="text-xl mb-1">💫</div>肯定语
          </button>
        </div>
      </div>

      <!-- 时长选择 -->
      <div class="glass-card p-4 mb-5">
        <div class="text-xs font-medium mb-3" style="color:var(--theme-text)">⏰ 选择时长</div>
        <div class="grid grid-cols-4 gap-2" id="timer-durations">
          <button onclick="selectTimerDuration(5)" class="timer-dur p-3 rounded-xl text-center text-sm font-title transition" style="background:rgba(184,169,201,0.1); color:var(--theme-text)">5分</button>
          <button onclick="selectTimerDuration(10)" class="timer-dur p-3 rounded-xl text-center text-sm font-title transition" style="background:rgba(184,169,201,0.1); color:var(--theme-text)">10分</button>
          <button onclick="selectTimerDuration(15)" class="timer-dur p-3 rounded-xl text-center text-sm font-title transition" style="background:rgba(184,169,201,0.1); color:var(--theme-text)">15分</button>
          <button onclick="selectTimerDuration(30)" class="timer-dur p-3 rounded-xl text-center text-sm font-title transition" style="background:rgba(184,169,201,0.1); color:var(--theme-text)">30分</button>
        </div>
      </div>

      <!-- 计时器显示 -->
      <div class="glass-card p-6 mb-5 text-center">
        <div class="relative w-48 h-48 mx-auto mb-4">
          <svg viewBox="0 0 100 100" class="w-full h-full -rotate-90">
            <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(184,169,201,0.15)" stroke-width="6"/>
            <circle id="timer-progress" cx="50" cy="50" r="45" fill="none" stroke="url(#timerGrad)" stroke-width="6" stroke-linecap="round" stroke-dasharray="283" stroke-dashoffset="0"/>
            <defs>
              <linearGradient id="timerGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#D4B5C7"/>
                <stop offset="100%" stop-color="#B8A9C9"/>
              </linearGradient>
            </defs>
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <div id="timer-display" class="font-display text-4xl" style="color:var(--theme-text)">05:00</div>
            <div id="timer-mode-text" class="text-xs mt-1" style="color:var(--theme-text); opacity:0.5">冥想</div>
          </div>
        </div>

        <div class="flex gap-2 justify-center">
          <button onclick="toggleTimer()" id="timer-toggle-btn" class="soft-btn btn-primary px-8 py-3 text-base font-title">
            ▶️ 开始
          </button>
          <button onclick="resetTimer()" class="soft-btn btn-soft px-6 py-3 text-base">
            🔄 重置
          </button>
        </div>
      </div>

      <!-- 小提示 -->
      <div class="glass-card p-4">
        <div class="text-xs font-medium mb-2" style="color:var(--theme-text)">💫 专注小提示</div>
        <p class="text-xs leading-relaxed" style="color:var(--theme-text); opacity:0.7" id="timer-tip">
          闭上眼睛，深呼吸，感受气息的进出。思绪飘走了也没关系，温柔地把注意力带回到呼吸上就好。
        </p>
      </div>
    </section>

    <!-- ========== 页面：显化工具（tab2） ========== -->
    <section id="page-tools" class="page">
      <div class="mb-5">
        <h2 class="font-display text-xl sm:text-2xl mb-1" style="color:var(--theme-text)">✨ 星愿百宝箱</h2>
        <p class="text-xs" style="color:var(--theme-text); opacity:0.6">选一个工具，开始今天的星愿练习吧 💫</p>
      </div>

      <!-- 测试类 -->
      <div class="glass-card p-4 mb-4">
        <h3 class="font-title text-sm mb-3" style="color:var(--theme-text)">🔍 自我探索</h3>
        <div class="grid grid-cols-2 gap-3">
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:linear-gradient(135deg, rgba(232,213,224,0.3), rgba(212,181,199,0.2))" onclick="openModule('temple')">
            <div class="text-3xl mb-2">💎</div>
            <div class="text-sm font-medium" style="color:var(--theme-text)">人格测试</div>
            <div class="text-[10px] mt-0.5" style="color:var(--theme-text); opacity:0.5">15题 · 解锁花公主</div>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:linear-gradient(135deg, rgba(201,216,232,0.3), rgba(155,181,200,0.2))" onclick="startTest('emotion')">
            <div class="text-3xl mb-2">🌈</div>
            <div class="text-sm font-medium" style="color:var(--theme-text)">情绪测试</div>
            <div class="text-[10px] mt-0.5" style="color:var(--theme-text); opacity:0.5">看看你在哪一层</div>
          </div>
        </div>
      </div>

      <!-- 核心练习 -->
      <div class="glass-card p-4 mb-4">
        <h3 class="font-title text-sm mb-3" style="color:var(--theme-text)">🌸 核心练习</h3>
        <div class="grid grid-cols-2 gap-3">
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:linear-gradient(135deg, rgba(212,197,224,0.3), rgba(184,169,201,0.2))" onclick="openModule('tower')">
            <div class="text-3xl mb-2">🔮</div>
            <div class="text-sm font-medium" style="color:var(--theme-text)">信念净化</div>
            <div class="text-[10px] mt-0.5" style="color:var(--theme-text); opacity:0.5">CBT三栏法</div>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:linear-gradient(135deg, rgba(245,230,200,0.3), rgba(232,200,122,0.2))" onclick="openModule('stars')">
            <div class="text-3xl mb-2">⭐</div>
            <div class="text-sm font-medium" style="color:var(--theme-text)">许愿星台</div>
            <div class="text-[10px] mt-0.5" style="color:var(--theme-text); opacity:0.5">BE-DO-HAVE</div>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:linear-gradient(135deg, rgba(224,232,242,0.4), rgba(201,216,232,0.3))" onclick="openModule('cloud')">
            <div class="text-3xl mb-2">☁️</div>
            <div class="text-sm font-medium" style="color:var(--theme-text)">SATS冥想</div>
            <div class="text-[10px] mt-0.5" style="color:var(--theme-text); opacity:0.5">睡前视觉化</div>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:linear-gradient(135deg, rgba(221,235,224,0.3), rgba(136,200,152,0.2))" onclick="openModule('garden')">
            <div class="text-3xl mb-2">🌸</div>
            <div class="text-sm font-medium" style="color:var(--theme-text)">行动花田</div>
            <div class="text-[10px] mt-0.5" style="color:var(--theme-text); opacity:0.5">灵感行动打卡</div>
          </div>
        </div>
      </div>

      <!-- 进阶工具 -->
      <div class="glass-card p-4 mb-4">
        <h3 class="font-title text-sm mb-3" style="color:var(--theme-text)">💫 进阶工具</h3>
        <div class="grid grid-cols-3 gap-3">
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:rgba(240,213,224,0.15)" onclick="openRevision()">
            <div class="text-2xl mb-1.5">🕊️</div>
            <div class="text-xs font-medium" style="color:var(--theme-text)">修正法</div>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:rgba(245,230,200,0.2)" onclick="openAffirmRadio()">
            <div class="text-2xl mb-1.5">🎵</div>
            <div class="text-xs font-medium" style="color:var(--theme-text)">肯定语电台</div>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:rgba(184,169,201,0.15)" onclick="openModule('tarot')">
            <div class="text-2xl mb-1.5">🃏</div>
            <div class="text-xs font-medium" style="color:var(--theme-text)">星辰塔罗占卜</div>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:rgba(221,235,224,0.2)" onclick="openModule('timer')">
            <div class="text-2xl mb-1.5">⏱️</div>
            <div class="text-xs font-medium" style="color:var(--theme-text)">专注计时</div>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:rgba(212,197,224,0.2)" onclick="openMentalDiet()">
            <div class="text-2xl mb-1.5">🧠</div>
            <div class="text-xs font-medium" style="color:var(--theme-text)">精神节食</div>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl text-center" style="background:rgba(245,213,213,0.2)" onclick="openModule('plans')">
            <div class="text-2xl mb-1.5">📋</div>
            <div class="text-xs font-medium" style="color:var(--theme-text)">显化计划</div>
          </div>
        </div>
      </div>

      <!-- 今日练习推荐 -->
      <div class="glass-card p-4" style="background:linear-gradient(135deg, rgba(240,213,224,0.2), rgba(184,169,201,0.15))">
        <div class="flex items-start gap-3">
          <div class="text-3xl shrink-0 animate-breath">💡</div>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium mb-1" style="color:var(--theme-text)">今日推荐练习</div>
            <p class="text-xs leading-relaxed" style="color:var(--theme-text); opacity:0.75" id="daily-tip-text">
              今天适合做SATS冥想。睡前花5分钟，视觉化你最想实现的愿望，带着那种满足感睡着～
            </p>
            <button onclick="openModule('cloud')" class="text-xs mt-2 font-medium" style="color:#B87590">去试试 →</button>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 页面：记录（tab4） ========== -->
    <section id="page-journal" class="page">
      <div class="mb-5">
        <h2 class="font-display text-xl sm:text-2xl mb-1" style="color:var(--theme-text)">📝 记录小屋</h2>
        <p class="text-xs" style="color:var(--theme-text); opacity:0.6">写下你的想法，记录每一步成长 💕</p>
      </div>

      <!-- 快速情绪花园 -->
      <div class="glass-card p-4 mb-4">
        <div class="text-xs font-medium mb-3" style="color:var(--theme-text)">💭 今天心情怎么样？</div>
        <div class="flex justify-around">
          <div class="text-center cursor-pointer mood-emoji" onclick="recordMood('happy')">
            <div class="text-2xl mb-1 transition-transform hover:scale-125">😊</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">开心</div>
          </div>
          <div class="text-center cursor-pointer mood-emoji" onclick="recordMood('calm')">
            <div class="text-2xl mb-1 transition-transform hover:scale-125">😌</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">平静</div>
          </div>
          <div class="text-center cursor-pointer mood-emoji" onclick="recordMood('meh')">
            <div class="text-2xl mb-1 transition-transform hover:scale-125">😐</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">有点down</div>
          </div>
          <div class="text-center cursor-pointer mood-emoji" onclick="recordMood('anxious')">
            <div class="text-2xl mb-1 transition-transform hover:scale-125">😰</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">焦虑</div>
          </div>
          <div class="text-center cursor-pointer mood-emoji" onclick="recordMood('sad')">
            <div class="text-2xl mb-1 transition-transform hover:scale-125">😢</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">难过</div>
          </div>
        </div>
      </div>

      <!-- 三种日记 -->
      <div class="glass-card p-4 mb-4">
        <h3 class="font-title text-sm mb-3" style="color:var(--theme-text)">📔 三种星辰日记</h3>
        <div class="space-y-2">
          <div class="card-hover cursor-pointer p-3 rounded-2xl flex items-center gap-3" style="background:rgba(240,213,224,0.15)" onclick="openModule('diary'); setTimeout(()=>selectDiaryTemplate('gratitude', document.querySelector('#page-diary .chip-soft')), 100)">
            <div class="text-2xl shrink-0">🙏</div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium" style="color:var(--theme-text)">感恩日记</div>
              <div class="text-[10px]" style="color:var(--theme-text); opacity:0.5">每天3件小事，培养丰盛感</div>
            </div>
            <span class="text-sm opacity-40">→</span>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl flex items-center gap-3" style="background:rgba(184,169,201,0.12)" onclick="openModule('diary'); setTimeout(()=>{const btns=document.querySelectorAll('#page-diary .chip-soft'); if(btns[1]) selectDiaryTemplate('future', btns[1]);}, 100)">
            <div class="text-2xl shrink-0">🔮</div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium" style="color:var(--theme-text)">未来日记</div>
              <div class="text-[10px]" style="color:var(--theme-text); opacity:0.5">以愿望已实现的身份写</div>
            </div>
            <span class="text-sm opacity-40">→</span>
          </div>
          <div class="card-hover cursor-pointer p-3 rounded-2xl flex items-center gap-3" style="background:rgba(245,230,200,0.25)" onclick="openModule('diary'); setTimeout(()=>{const btns=document.querySelectorAll('#page-diary .chip-soft'); if(btns[2]) selectDiaryTemplate('success', btns[2]);}, 100)">
            <div class="text-2xl shrink-0">🎉</div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium" style="color:var(--theme-text)">星愿成真日志</div>
              <div class="text-[10px]" style="color:var(--theme-text); opacity:0.5">记录大小显化，积累证据</div>
            </div>
            <span class="text-sm opacity-40">→</span>
          </div>
        </div>
      </div>

      <!-- 记录入口网格 -->
      <div class="grid grid-cols-2 gap-3 mb-4">
        <div class="glass-card p-4 card-hover cursor-pointer" onclick="openModule('garden')">
          <div class="text-3xl mb-2">🌸</div>
          <div class="text-sm font-medium mb-0.5" style="color:var(--theme-text)">行动花田</div>
          <div class="text-[10px]" style="color:var(--theme-text); opacity:0.5">种灵感小行动</div>
        </div>
        <div class="glass-card p-4 card-hover cursor-pointer" onclick="openModule('wishwall')">
          <div class="text-3xl mb-2">🪧</div>
          <div class="text-sm font-medium mb-0.5" style="color:var(--theme-text)">心愿墙</div>
          <div class="text-[10px]" style="color:var(--theme-text); opacity:0.5">看许过的愿望</div>
        </div>
      </div>

      <!-- 习惯打卡 -->
      <div class="glass-card p-4 mb-4">
        <div class="flex items-center justify-between mb-3">
          <h3 class="font-title text-sm" style="color:var(--theme-text)">✅ 今日习惯</h3>
          <button onclick="openHabitModal()" class="text-xs" style="color:var(--theme-text); opacity:0.6">+ 添加</button>
        </div>
        <div id="journal-habit-list" class="space-y-2">
          <div class="text-center py-4 text-xs" style="color:var(--theme-text); opacity:0.4">
            添加第一个显化习惯吧 🌱
          </div>
        </div>
      </div>

      <!-- 成长数据概览 -->
      <div class="glass-card p-4">
        <div class="flex items-center justify-between mb-3">
          <h3 class="font-title text-sm" style="color:var(--theme-text)">📊 成长数据</h3>
          <button onclick="openGrowthPage()" class="text-xs" style="color:var(--theme-text); opacity:0.6">详情 →</button>
        </div>
        <div class="grid grid-cols-4 gap-2 text-center">
          <div class="p-2 rounded-xl" style="background:rgba(240,213,224,0.15)">
            <div class="text-lg font-title" style="color:#D4A5B8" id="journal-stat-wishes">0</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">愿望</div>
          </div>
          <div class="p-2 rounded-xl" style="background:rgba(184,169,201,0.15)">
            <div class="text-lg font-title" style="color:#8B7E9C" id="journal-stat-purify">0</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">净化</div>
          </div>
          <div class="p-2 rounded-xl" style="background:rgba(136,200,152,0.2)">
            <div class="text-lg font-title" style="color:#5A9C6A" id="journal-stat-flowers">0</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">花朵</div>
          </div>
          <div class="p-2 rounded-xl" style="background:rgba(245,230,200,0.3)">
            <div class="text-lg font-title" style="color:#D4A85A" id="journal-stat-days">1</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">天数</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 页面：我的（tab5） ========== -->
    <section id="page-me" class="page">
      <div class="mb-5">
        <h2 class="font-display text-xl sm:text-2xl mb-1" style="color:var(--theme-text)">👸 我的星空</h2>
        <p class="text-xs" style="color:var(--theme-text); opacity:0.6">你的专属小宇宙，闪闪发亮 ✨</p>
      </div>

      <!-- 个人信息卡 -->
      <div class="glass-card p-5 mb-4 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 rounded-bl-full" style="background:linear-gradient(135deg, rgba(240,213,224,0.3), transparent)"></div>
        <div class="flex items-center gap-4 mb-4 relative">
          <div id="me-avatar" class="w-16 h-16 rounded-full flex items-center justify-center text-3xl shrink-0 animate-breath overflow-hidden" style="background:linear-gradient(135deg, #F5E1EA, #D4B5C7, #B8A9C9); border:3px solid white">
            🌸
          </div>
          <div class="min-w-0 flex-1">
            <input type="text" id="me-nickname" value="小公主"
              class="bg-transparent border-b-2 border-dashed focus:outline-none w-full font-display text-lg"
              style="border-color:rgba(212,181,199,0.4); color:var(--theme-text)"
              onchange="updateNickname(this.value)"/>
            <div class="flex items-center gap-2 mt-1">
              <span class="level-badge" id="me-level">新手</span>
              <span class="text-xs" style="color:var(--theme-text); opacity:0.5" id="me-persona-name">待解锁</span>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-4 gap-1.5">
          <div class="text-center p-2 rounded-lg" style="background:rgba(245,213,213,0.2)">
            <div class="text-base font-title" style="color:#D4A5B8" id="me-energy">0</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">💎 能量</div>
          </div>
          <div class="text-center p-2 rounded-lg" style="background:rgba(184,169,201,0.15)">
            <div class="text-base font-title" style="color:#8B7E9C" id="me-wishes">0</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">⭐ 愿望</div>
          </div>
          <div class="text-center p-2 rounded-lg" style="background:rgba(136,200,152,0.2)">
            <div class="text-base font-title" style="color:#5A9C6A" id="me-flowers">0</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">🌸 花</div>
          </div>
          <div class="text-center p-2 rounded-lg" style="background:rgba(245,230,200,0.3)">
            <div class="text-base font-title" style="color:#D4A85A" id="me-badges">0</div>
            <div class="text-[10px]" style="color:var(--theme-text); opacity:0.6">🏅 徽章</div>
          </div>
        </div>
      </div>

      <!-- 我的专属星光水晶 -->
      <div class="glass-card p-4 mb-4 card-hover cursor-pointer" onclick="openCrystalPage()">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl shrink-0" style="background:linear-gradient(135deg, #E8DEEF, #B8A9C9)">💎</div>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium" style="color:var(--theme-text)">我的专属星光水晶</div>
            <div class="text-[10px] mt-0.5" style="color:var(--theme-text); opacity:0.5">收集星光水晶，提升你的星光能量</div>
          </div>
          <span class="text-sm opacity-40">→</span>
        </div>
      </div>

      <!-- 功能入口网格 -->
      <div class="glass-card p-4 mb-4">
        <h3 class="font-title text-sm mb-3" style="color:var(--theme-text)">📦 我的收藏</h3>
        <div class="grid grid-cols-4 gap-3">
          <div class="text-center cursor-pointer card-hover" onclick="openAffirmCollection()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(240,213,224,0.2)">💖</div>
            <div class="text-[11px]" style="color:var(--theme-text)">肯定语</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="openCardCollection()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(245,230,200,0.25)">🎴</div>
            <div class="text-[11px]" style="color:var(--theme-text)">卡册</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="openBadgeWall()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(212,197,224,0.25)">🏆</div>
            <div class="text-[11px]" style="color:var(--theme-text)">徽章</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="openModule('growth')">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(201,216,232,0.25)">📈</div>
            <div class="text-[11px]" style="color:var(--theme-text)">成长</div>
          </div>
        </div>
      </div>

      <!-- 公主身份 -->
      <div class="glass-card p-4 mb-4">
        <h3 class="font-title text-sm mb-3" style="color:var(--theme-text)">👑 公主身份</h3>
        <div id="me-persona-card" class="text-center py-4 text-sm" style="color:var(--theme-text); opacity:0.4">
          完成人格测试，解锁你的专属花公主身份 ✨
          <button onclick="openModule('temple')" class="block mx-auto mt-2 text-xs" style="color:#B8A9C9">去测试 →</button>
        </div>
      </div>

      <!-- 更多探索 -->
      <div class="glass-card p-4 mb-4">
        <h3 class="font-title text-sm mb-3" style="color:var(--theme-text)">🚀 更多探索</h3>
        <div class="grid grid-cols-3 gap-3">
          <div class="text-center cursor-pointer card-hover" onclick="showPage('reports');initReports()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(212,181,199,0.2)">📊</div>
            <div class="text-[11px]" style="color:var(--theme-text)">周报</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('community');renderCommunityFeed()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(245,230,200,0.25)">🌟</div>
            <div class="text-[11px]" style="color:var(--theme-text)">广场</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('vip');initVip()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(136,200,152,0.2)">💎</div>
            <div class="text-[11px]" style="color:var(--theme-text)">星光</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('shop')">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(254,243,199,0.4)">🛍️</div>
            <div class="text-[11px]" style="color:var(--theme-text)">周边</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('coach')">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(232,181,200,0.2)">🌙</div>
            <div class="text-[11px]" style="color:var(--theme-text)">显化教练</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="openSearch()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(184,169,201,0.2)">🔍</div>
            <div class="text-[11px]" style="color:var(--theme-text)">搜索</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('reports');initReports()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(201,216,232,0.3)">📈</div>
            <div class="text-[11px]" style="color:var(--theme-text)">报告</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="toggleDarkMode()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" id="dark-mode-toggle" style="background:rgba(45,38,62,0.15)">🌙</div>
            <div class="text-[11px]" style="color:var(--theme-text)">深色</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showFeedbackModal()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(201,216,232,0.25)">💌</div>
            <div class="text-[11px]" style="color:var(--theme-text)">反馈</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('breathe');initBreathe()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(184,169,201,0.2)">🌬️</div>
            <div class="text-[11px]" style="color:var(--theme-text)">呼吸</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('voice');initVoice()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(212,181,199,0.25)">🎙️</div>
            <div class="text-[11px]" style="color:var(--theme-text)">声音</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('sleep');initSleep()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(45,38,62,0.15)">🌙</div>
            <div class="text-[11px]" style="color:var(--theme-text)">睡眠</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('badge-wall');initBadgeWall()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:linear-gradient(135deg,rgba(245,230,200,0.4),rgba(212,181,199,0.2))">🏆</div>
            <div class="text-[11px]" style="color:var(--theme-text)">成就</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('vision');initVisionBoard()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:linear-gradient(135deg,rgba(212,181,199,0.3),rgba(184,169,201,0.2))">🖼️</div>
            <div class="text-[11px]" style="color:var(--theme-text)">愿景</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('qr-sync')">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(201,216,232,0.3)">📲</div>
            <div class="text-[11px]" style="color:var(--theme-text)">同步</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('emotion');initEmotion()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(212,181,199,0.3)">📈</div>
            <div class="text-[11px]" style="color:var(--theme-text)">情绪</div>
          </div>
          <div class="text-center cursor-pointer card-hover" onclick="showPage('habit-calendar');initHabitCalendar()">
            <div class="w-12 h-12 mx-auto mb-1.5 rounded-2xl flex items-center justify-center text-xl" style="background:rgba(201,216,232,0.3)">📅</div>
            <div class="text-[11px]" style="color:var(--theme-text)">日历</div>
          </div>
        </div>
      </div>

      <!-- 设置入口 -->
      <div class="glass-card overflow-hidden">
        <button onclick="openSettings()" class="w-full p-4 text-left card-hover flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center text-lg shrink-0" style="background:rgba(184,169,201,0.15)">⚙️</div>
          <div class="flex-1">
            <div class="text-sm font-medium" style="color:var(--theme-text)">设置</div>
            <div class="text-xs" style="color:var(--theme-text); opacity:0.5">声音 · 主题 · 隐私 · 数据</div>
          </div>
          <span style="color:var(--theme-text); opacity:0.3">→</span>
        </button>
      </div>
    </section>

  </div>
</main>

<!-- 底部导航 -->
<nav class="bottom-nav" id="bottom-nav">
  <div class="max-w-6xl mx-auto flex justify-around px-2">
    <div class="nav-item active" onclick="switchTab('island')" id="nav-island">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12 L12 3 L21 12"/>
        <path d="M5 10 V21 H19 V10"/>
      </svg>
      <span>岛屿</span>
    </div>
    <div class="nav-item" onclick="switchTab('tools')" id="nav-tools">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2 L15 8 L22 9 L17 14 L18 21 L12 18 L6 21 L7 14 L2 9 L9 8 Z"/>
      </svg>
      <span>显化</span>
    </div>
    <div class="nav-item" onclick="switchTab('library')" id="nav-library">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4 H8 V20 H4 Z"/>
        <path d="M10 4 H14 V20 H10 Z"/>
        <path d="M16 4 L20 6 V19 L16 21 Z"/>
      </svg>
      <span>书馆</span>
    </div>
    <div class="nav-item" onclick="switchTab('journal')" id="nav-journal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 3 H18 A2 2 0 0 1 20 5 V21 L16 18 L12 21 L8 18 L4 21 V5 A2 2 0 0 1 6 3 Z"/>
        <path d="M8 8 H16"/>
        <path d="M8 12 H16"/>
        <path d="M8 16 H12"/>
      </svg>
      <span>记录</span>
    </div>
    <div class="nav-item" onclick="switchTab('me')" id="nav-me">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 21 C4 16 8 14 12 14 C16 14 20 16 20 21"/>
      </svg>
      <span>我的</span>
    </div>
  </div>
</nav>

<!-- ========== Modal：测试 ========== -->
<div id="test-modal" class="modal-backdrop" onclick="if(event.target===this)closeTest()">
  <div class="modal-content p-5" onclick="event.stopPropagation()">
    <div id="test-content"></div>
  </div>
</div>

<!-- ========== Modal：人格详情 ========== -->
<div id="persona-modal" class="modal-backdrop">
  <div class="modal-content">
    <div id="persona-detail"></div>
  </div>
</div>

<!-- ========== Modal：通用提示 ========== -->
<div id="alert-modal" class="modal-backdrop">
  <div class="modal-content p-6 text-center max-w-sm">
    <div class="text-5xl mb-3" id="alert-icon">💖</div>
    <h3 class="font-display text-lg mb-2" style="color:var(--theme-text)" id="alert-title">公主殿下</h3>
    <p class="text-sm mb-5 whitespace-pre-line" style="color:var(--theme-text); opacity:0.75" id="alert-text">内容</p>
    <button onclick="closeAlert()" class="soft-btn btn-primary w-full py-3 font-title">
      好的呀～
    </button>
  </div>
</div>

<!-- ========== Modal：自定义肯定语 ========== -->
<div id="affirm-modal" class="modal-backdrop">
  <div class="modal-content p-5 max-w-md">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-display text-lg" style="color:var(--theme-text)">添加自定义肯定语</h3>
      <button onclick="closeAffirmModal()" class="text-lg" style="color:var(--theme-text); opacity:0.4">×</button>
    </div>
    <div class="space-y-3">
      <div>
        <label class="text-xs mb-1 block" style="color:var(--theme-text); opacity:0.6">选择分类：</label>
        <select id="custom-affirm-cat" class="dream-input text-sm">
          <option value="love">💖 恋爱SP</option>
          <option value="money">💰 财富事业</option>
          <option value="beauty">✨ 美貌自信</option>
          <option value="heal">🧘 情绪疗愈</option>
          <option value="self">🌱 自我概念</option>
        </select>
      </div>
      <div>
        <label class="text-xs mb-1 block" style="color:var(--theme-text); opacity:0.6">肯定语内容：</label>
        <textarea id="custom-affirm-text" rows="3" placeholder="写下属于你的肯定语..." class="dream-input text-sm"></textarea>
      </div>
      <button onclick="addCustomAffirm()" class="soft-btn btn-primary w-full py-3 font-title">
        💖 添加到我的收藏
      </button>
    </div>
  </div>
</div>

<!-- ========== Modal：书本详情 ========== -->
<div id="book-modal" class="modal-backdrop">
  <div class="modal-content max-w-md">
    <div class="relative">
      <button onclick="closeBookModal()" class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full z-10" style="background:rgba(255,255,255,0.5); color:var(--theme-text); opacity:0.6">×</button>
      <div id="book-detail-content" class="p-5"></div>
    </div>
  </div>
</div>

<!-- ========== Modal：书籍翻书阅读 ========== -->
<div id="book-reader-modal" class="modal-backdrop" style="z-index:1500">
  <div class="modal-content max-w-4xl w-full mx-4" style="padding:0; overflow:hidden; background:transparent; box-shadow:none">
    <!-- 顶部工具栏 -->
    <div class="flex items-center justify-between px-4 py-3" style="background:rgba(255,255,255,0.1); backdrop-filter:blur(10px); border-radius:20px 20px 0 0">
      <div class="flex items-center gap-2 min-w-0">
        <button onclick="closeBookReader()" class="w-8 h-8 flex items-center justify-center rounded-full shrink-0" style="background:rgba(255,255,255,0.3); color:var(--theme-text)">←</button>
        <div class="min-w-0">
          <div class="font-title text-sm truncate" style="color:var(--theme-text)" id="reader-book-title"></div>
          <div class="text-[10px] truncate" style="color:var(--theme-text); opacity:0.5" id="reader-book-author"></div>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button onclick="toggleBookmark()" id="bookmark-btn" class="w-8 h-8 flex items-center justify-center rounded-full transition-all" style="background:rgba(255,255,255,0.3); color:var(--theme-text)" title="书签">🔖</button>
        <button onclick="toggleNotePanel()" id="note-btn" class="w-8 h-8 flex items-center justify-center rounded-full transition-all" style="background:rgba(255,255,255,0.3); color:var(--theme-text)" title="笔记">📝</button>
        <button onclick="toggleToc()" class="w-8 h-8 flex items-center justify-center rounded-full" style="background:rgba(255,255,255,0.3); color:var(--theme-text)" title="目录">☰</button>
      </div>
    </div>
    
    <!-- 书页区域 -->
    <div class="relative" style="perspective:1500px">
      <div id="book-container" class="relative mx-auto" style="width:100%; max-width:700px; aspect-ratio:3/4; max-height:60vh">
        <!-- 左页 -->
        <div id="page-left" class="absolute top-0 left-0 w-1/2 h-full overflow-hidden" style="background:linear-gradient(to right, #FDF8F0, #F5EDE0); border-radius:12px 0 0 12px; box-shadow:-4px 4px 20px rgba(0,0,0,0.1); transform-origin:right center">
          <div class="p-6 h-full overflow-y-auto book-page-content" id="page-left-content"></div>
        </div>
        <!-- 右页 -->
        <div id="page-right" class="absolute top-0 right-0 w-1/2 h-full overflow-hidden" style="background:linear-gradient(to left, #FDF8F0, #F5EDE0); border-radius:0 12px 12px 0; box-shadow:4px 4px 20px rgba(0,0,0,0.1); transform-origin:left center">
          <div class="p-6 h-full overflow-y-auto book-page-content" id="page-right-content"></div>
        </div>
        <!-- 书脊阴影 -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-4 h-full" style="background:linear-gradient(to right, rgba(0,0,0,0.08), transparent 30%, transparent 70%, rgba(0,0,0,0.08)); pointer-events:none"></div>
      </div>
    </div>
    
    <!-- 底部翻页控制 -->
    <div class="flex items-center justify-between px-4 py-3" style="background:rgba(255,255,255,0.1); backdrop-filter:blur(10px); border-radius:0 0 20px 20px">
      <button onclick="prevPage()" id="prev-page-btn" class="soft-btn px-4 py-2 rounded-xl text-sm" style="background:rgba(255,255,255,0.3); color:var(--theme-text)">← 上一页</button>
      <div class="text-sm" style="color:var(--theme-text)">
        <span id="current-page">1</span> / <span id="total-pages">1</span>
      </div>
      <button onclick="nextPage()" id="next-page-btn" class="soft-btn px-4 py-2 rounded-xl text-sm" style="background:rgba(255,255,255,0.3); color:var(--theme-text)">下一页 →</button>
    </div>
    
    <!-- 笔记面板 -->
    <div id="note-panel" class="hidden absolute right-4 top-16 bottom-16 w-64 rounded-2xl p-4 z-10" style="background:rgba(255,255,255,0.95); backdrop-filter:blur(20px); box-shadow:0 8px 32px rgba(0,0,0,0.15)">
      <div class="flex items-center justify-between mb-3">
        <div class="font-title text-sm" style="color:var(--theme-text)">📝 我的笔记</div>
        <button onclick="toggleNotePanel()" class="text-sm" style="color:var(--theme-text); opacity:0.4">×</button>
      </div>
      <textarea id="note-textarea" oninput="saveCurrentNote()" placeholder="在这里写下你的读书笔记、感悟、灵感..." class="w-full h-40 p-3 rounded-xl text-sm resize-none outline-none" style="background:rgba(184,169,201,0.1); color:var(--theme-text); border:1px solid rgba(184,169,201,0.2)"></textarea>
      <div class="text-[10px] mt-2" style="color:var(--theme-text); opacity:0.4">💡 笔记会自动保存在这一页哦</div>
      <div class="mt-3 max-h-32 overflow-y-auto space-y-2" id="notes-list"></div>
    </div>
    
    <!-- 目录面板 -->
    <div id="toc-panel" class="hidden absolute left-4 top-16 bottom-16 w-56 rounded-2xl p-4 z-10" style="background:rgba(255,255,255,0.95); backdrop-filter:blur(20px); box-shadow:0 8px 32px rgba(0,0,0,0.15)">
      <div class="flex items-center justify-between mb-3">
        <div class="font-title text-sm" style="color:var(--theme-text)">📑 目录</div>
        <button onclick="toggleToc()" class="text-sm" style="color:var(--theme-text); opacity:0.4">×</button>
      </div>
      <div class="space-y-1 overflow-y-auto max-h-full" id="toc-list"></div>
    </div>
  </div>
</div>
<div id="diary-modal" class="modal-backdrop">
  <div class="modal-content max-w-md">
    <div class="p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-display text-lg" style="color:var(--theme-text)">📔 我的日记本</h3>
        <button onclick="closeDiaryModal()" class="text-lg" style="color:var(--theme-text); opacity:0.4">×</button>
      </div>
      <div id="diary-history-list" class="space-y-3 max-h-96 overflow-y-auto">
        <div class="text-center py-10">
          <div class="text-4xl mb-3">📔</div>
          <p class="text-sm mb-4" style="color:var(--theme-text); opacity:0.6">还没有写过日记哦～</p>
          <p class="text-xs mb-5" style="color:var(--theme-text); opacity:0.4">写日记不是任务，是和自己温柔对话的时间 💕</p>
          <button onclick="closeDiaryModal(); switchTab('journal')" class="soft-btn btn-primary px-6 py-2.5 text-sm font-title">去写第一篇日记 ✨</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ========== Modal：课程详情 ========== -->
<div id="course-modal" class="modal-backdrop">
  <div class="modal-content max-w-lg">
    <div class="relative">
      <button onclick="closeCourseModal()" class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full z-10" style="background:rgba(255,255,255,0.5); color:var(--theme-text); opacity:0.6">×</button>
      <div id="course-detail-content" class="p-5"></div>
    </div>
  </div>
</div>

<!-- ========== Modal：设置中心 ========== -->
<div id="settings-modal" class="modal-backdrop">
  <div class="modal-content max-w-md max-h-[90vh] overflow-y-auto">
    <div class="p-5">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-display text-xl" style="color:var(--theme-text)">⚙️ 设置</h3>
        <button onclick="closeSettings()" class="w-9 h-9 flex items-center justify-center rounded-full" style="background:rgba(184,169,201,0.1); color:var(--theme-text); opacity:0.6">×</button>
      </div>

      <!-- 声音设置 -->
      <div class="settings-group">
        <div class="settings-group-title">🔊 声音设置</div>

        <div class="mb-4">
          <div class="text-xs mb-2" style="color:var(--theme-text); opacity:0.6">气泡风格</div>
          <div class="grid grid-cols-5 gap-2">
            <div class="voice-option active" onclick="selectVoice('girl1', this)">
              <div class="text-xl mb-1">🌸</div>
              <div class="text-[10px]" style="color:var(--theme-text)">樱花粉</div>
            </div>
            <div class="voice-option" onclick="selectVoice('woman', this)">
              <div class="text-xl mb-1">💜</div>
              <div class="text-[10px]" style="color:var(--theme-text)">梦幻紫</div>
            </div>
            <div class="voice-option" onclick="selectVoice('loli', this)">
              <div class="text-xl mb-1">💛</div>
              <div class="text-[10px]" style="color:var(--theme-text)">奶油黄</div>
            </div>
            <div class="voice-option" onclick="selectVoice('boy', this)">
              <div class="text-xl mb-1">💚</div>
              <div class="text-[10px]" style="color:var(--theme-text)">薄荷绿</div>
            </div>
            <div class="voice-option" onclick="selectVoice('man', this)">
              <div class="text-xl mb-1">💙</div>
              <div class="text-[10px]" style="color:var(--theme-text)">天空蓝</div>
            </div>
          </div>
        </div>

        <div class="settings-item" style="cursor:default">
          <div class="settings-item-label">
            <div class="settings-item-icon">🎵</div>
            <span>背景音乐</span>
          </div>
          <div class="flex items-center gap-2 flex-1 max-w-[140px] justify-end">
            <span class="text-xs" style="color:var(--theme-text); opacity:0.5" id="vol-music-val">30%</span>
            <input type="range" min="0" max="100" value="30" class="w-20" oninput="setVolume('music', this.value)"/>
          </div>
        </div>

        <div class="settings-item" style="cursor:default">
          <div class="settings-item-label">
            <div class="settings-item-icon">🔔</div>
            <span>操作音效</span>
          </div>
          <div class="flex items-center gap-2 flex-1 max-w-[140px] justify-end">
            <span class="text-xs" style="color:var(--theme-text); opacity:0.5" id="vol-sfx-val">50%</span>
            <input type="range" min="0" max="100" value="50" class="w-20" oninput="setVolume('sfx', this.value)"/>
          </div>
        </div>

        <div class="settings-item" onclick="toggleSetting('voiceOn', this.querySelector('.toggle-switch'))">
          <div class="settings-item-label">
            <div class="settings-item-icon">💬</div>
            <span>气泡提示</span>
          </div>
          <div class="toggle-switch" id="toggle-voice"></div>
        </div>

        <div class="mt-3">
          <div class="text-xs mb-2" style="color:var(--theme-text); opacity:0.6">白噪音</div>
          <div class="flex gap-2 flex-wrap">
            <button class="chip-soft" onclick="toggleWhiteNoise('rain', this)">🌧️ 细雨</button>
            <button class="chip-soft" onclick="toggleWhiteNoise('forest', this)">🌲 森林</button>
            <button class="chip-soft" onclick="toggleWhiteNoise('ocean', this)">🌊 海浪</button>
            <button class="chip-soft" onclick="toggleWhiteNoise('fire', this)">🔥 篝火</button>
            <button class="chip-soft" onclick="toggleWhiteNoise('cafe', this)">☕ 咖啡馆</button>
          </div>
        </div>

        <div class="settings-item mt-3">
          <div class="settings-item-label">
            <div class="settings-item-icon">💫</div>
            <span>进入页面气泡提示</span>
          </div>
          <div class="toggle-switch on" id="toggle-autoplay" onclick="toggleSetting('autoplay', this)"></div>
        </div>
      </div>

      <!-- 个性化设置 -->
      <div class="settings-group">
        <div class="settings-group-title">🎨 个性化</div>

        <div class="settings-item" style="cursor:default">
          <div class="settings-item-label">
            <div class="settings-item-icon">🎨</div>
            <span>主题色</span>
          </div>
          <div class="flex gap-2">
            <div class="theme-dot active" style="background:linear-gradient(135deg, #F5E1EA, #D4B5C7)" onclick="setTheme('pink', this)" title="粉紫"></div>
            <div class="theme-dot" style="background:linear-gradient(135deg, #D4C5E0, #A898BC)" onclick="setTheme('purple', this)" title="薰衣草"></div>
            <div class="theme-dot" style="background:linear-gradient(135deg, #DCE8F2, #9DB5C8)" onclick="setTheme('blue', this)" title="雾蓝"></div>
            <div class="theme-dot" style="background:linear-gradient(135deg, #DDEBE0, #88C898)" onclick="setTheme('green', this)" title="薄荷"></div>
          </div>
        </div>

        <div class="settings-item">
          <div class="settings-item-label">
            <div class="settings-item-icon">🌤️</div>
            <span>岛屿天气</span>
          </div>
          <div class="flex items-center gap-2 text-xs" style="color:var(--theme-text); opacity:0.6">
            <span id="weather-setting-text">自动</span>
            <button onclick="cycleWeatherSetting()" class="text-xs" style="color:#B8A9C9">切换 →</button>
          </div>
        </div>

        <div class="settings-item">
          <div class="settings-item-label">
            <div class="settings-item-icon">✨</div>
            <span>动效</span>
          </div>
          <div class="toggle-switch on" id="toggle-animation" onclick="toggleSetting('animation', this)"></div>
        </div>

        <div class="settings-item">
          <div class="settings-item-label">
            <div class="settings-item-icon">🌙</div>
            <span>深色模式</span>
          </div>
          <div class="toggle-switch" id="toggle-darkmode" onclick="toggleSetting('darkmode', this)"></div>
        </div>
      </div>

      <!-- 隐私设置 -->
      <div class="settings-group">
        <div class="settings-group-title">🔒 隐私</div>

        <div class="settings-item" onclick="setupPassword()">
          <div class="settings-item-label">
            <div class="settings-item-icon">🔐</div>
            <span>密码锁</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs" style="color:var(--theme-text); opacity:0.5" id="password-status">未设置</span>
            <div class="toggle-switch" id="toggle-password" onclick="event.stopPropagation(); togglePassword()"></div>
          </div>
        </div>

        <div class="settings-item">
          <div class="settings-item-label">
            <div class="settings-item-icon">💾</div>
            <span>仅本地保存</span>
          </div>
          <div class="toggle-switch on" id="toggle-localonly" onclick="toggleSetting('localonly', this)"></div>
        </div>
      </div>

      <!-- 提醒设置 -->
      <div class="settings-group">
        <div class="settings-group-title">⏰ 提醒</div>

        <div class="settings-item">
          <div class="settings-item-label">
            <div class="settings-item-icon">📅</div>
            <span>每日打卡提醒</span>
          </div>
          <div class="toggle-switch" id="toggle-remind" onclick="toggleSetting('remind', this)"></div>
        </div>

        <div class="settings-item" style="cursor:default">
          <div class="settings-item-label">
            <div class="settings-item-icon">🧘</div>
            <span>冥想提醒</span>
          </div>
          <div class="flex items-center gap-2">
            <input type="time" id="meditation-time" value="22:00" class="dream-input text-xs !py-1.5 !px-2 w-20 text-center" onchange="saveReminderTime()"/>
          </div>
        </div>

        <div class="settings-item" style="cursor:default">
          <div class="settings-item-label">
            <div class="settings-item-icon">💖</div>
            <span>肯定语推送</span>
          </div>
          <div class="flex items-center gap-2">
            <input type="time" id="affirm-time" value="09:00" class="dream-input text-xs !py-1.5 !px-2 w-20 text-center" onchange="saveReminderTime()"/>
          </div>
        </div>
      </div>

      <!-- 数据设置 -->
      <div class="settings-group">
        <div class="settings-group-title">📦 数据</div>

        <div class="settings-item" onclick="exportData()">
          <div class="settings-item-label">
            <div class="settings-item-icon">📤</div>
            <span>导出所有数据</span>
          </div>
          <span style="color:var(--theme-text); opacity:0.3">→</span>
        </div>

        <div class="settings-item" onclick="clearCache()">
          <div class="settings-item-label">
            <div class="settings-item-icon">🗑️</div>
            <span>清除缓存</span>
          </div>
          <span style="color:var(--theme-text); opacity:0.3">→</span>
        </div>

        <div class="settings-item" onclick="showPage('about');initAbout()">
          <div class="settings-item-label">
            <div class="settings-item-icon">ℹ️</div>
            <span>关于星愿花园</span>
          </div>
          <span style="color:var(--theme-text); opacity:0.3">→</span>
        </div>

