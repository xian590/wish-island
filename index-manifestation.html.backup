      <div class="text-3xl mb-2">📅</div>
      <h2 class="text-xl font-medium mb-1" style="font-family:'ZCOOL XiaoWei',sans-serif">你的星愿足迹</h2>
      <p class="text-sm" style="color:var(--text-soft)">每一天的记录都是向宇宙发送的信号</p>
    </div>
    
    <div class="glass-card p-4 mb-4">
      <div class="flex items-center justify-between mb-4">
        <button onclick="changeHabitMonth(-1)" class="btn-soft px-3 py-1 rounded-lg text-sm">◀ 上月</button>
        <div id="habit-calendar-title" class="text-sm font-medium" style="color:var(--theme-text)">2025年 7月</div>
        <button onclick="changeHabitMonth(1)" class="btn-soft px-3 py-1 rounded-lg text-sm">下月 ▶</button>
      </div>
      <div id="habit-calendar-grid"></div>
    </div>
    
    <div class="glass-card p-4">
      <h3 class="text-sm font-medium mb-2" style="color:var(--theme-text)">📖 图例</h3>
      <div class="flex gap-4 text-xs" style="color:var(--text-soft)">
        <div class="flex items-center gap-1"><div style="width:12px;height:12px;border-radius:3px;background:rgba(255,255,255,0.5);border:1px solid rgba(212,181,199,0.2)"></div> 无记录</div>
        <div class="flex items-center gap-1"><div style="width:12px;height:12px;border-radius:3px;background:rgba(212,181,199,0.4)"></div> 有活动</div>
        <div class="flex items-center gap-1"><div style="width:12px;height:12px;border-radius:3px;background:linear-gradient(135deg,#D4B5C7,#B8A9C9)"></div> 高能量</div>
      </div>
    </div>
  </div>
</section>

