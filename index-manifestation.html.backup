          <span class="text-[10px] px-2 py-1 rounded-full" style="background:rgba(212,181,199,0.15);color:var(--text-soft)">全部会员功能</span>
          <span class="text-[10px] px-2 py-1 rounded-full" style="background:rgba(212,181,199,0.15);color:var(--text-soft)">省 ¥88</span>
