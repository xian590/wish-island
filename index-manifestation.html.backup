    { text: '理性分析和各种数据', scores: { action: 0, create: 3, empathy: 0, stable: 2, charm: 0 } },
    { text: '过往经验，稳妥为主', scores: { action: 0, create: 0, empathy: 0, stable: 3, charm: 0 } },
    { text: '内心感受和对他人的影响', scores: { action: 0, create: 0, empathy: 3, stable: 1, charm: 0 } },
    { text: '看哪种选择让我更有魅力', scores: { action: 1, create: 1, empathy: 1, stable: 0, charm: 3 } },
  ]},
