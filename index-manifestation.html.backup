        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="text-[10px] px-2 py-1 rounded-full" style="background:rgba(245,158,11,0.15);color:#B45309">全部会员功能</span>
          <span class="text-[10px] px-2 py-1 rounded-full" style="background:rgba(245,158,11,0.15);color:#B45309">AI 深度显化教练</span>
          <span class="text-[10px] px-2 py-1 rounded-full" style="background:rgba(245,158,11,0.15);color:#B45309">无限对话</span>
          <span class="text-[10px] px-2 py-1 rounded-full" style="background:rgba(245,158,11,0.15);color:#B45309">优先响应</span>
        </div>
        <button onclick="selectSubscriptionPlan('vip_month')" class="w-full py-3 rounded-xl text-white font-medium" style="background:linear-gradient(135deg,#F59E0B,#D97706)">选择高级会员</button>
