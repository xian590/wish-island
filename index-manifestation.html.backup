<!-- ========== AI 宇宙闺蜜 ========== -->
<section id="page-ai" class="page" style="padding-bottom:100px;">
  <div class="glass-header sticky top-0 z-40 px-5 py-4">
    <div class="flex items-center justify-between max-w-lg mx-auto">
      <button onclick="goHome()" class="soft-btn w-10 h-10 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,0.6)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
      <div class="text-center">
        <h1 class="text-lg font-medium" style="color:var(--theme-text)">宇宙闺蜜</h1>
        <p class="text-xs" style="color:var(--text-mute)">你的专属显化陪伴</p>
      </div>
      <div class="w-10"></div>
    </div>
  </div>
  <div class="max-w-lg mx-auto px-5 py-6">
    <div id="ai-chat-area" class="space-y-4 mb-4" style="min-height:300px">
      <div class="flex items-start gap-3">
        <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 text-white text-sm" style="background:linear-gradient(135deg,#E8B5C8,#C8A5D8)">🌙</div>
        <div class="p-4 rounded-2xl rounded-tl-sm text-sm" style="background:rgba(255,255,255,0.8);color:var(--theme-text);max-width:75%">嗨呀～我是你的宇宙闺蜜 🌙<br><br>今天心情怎么样？有什么想要显化的事情吗？你可以告诉我，我会陪你一起梳理情绪、设定意图，或者只是聊聊天 💕</div>
      </div>
    </div>
    <div class="flex gap-2 flex-wrap mb-3">
      <button onclick="sendAiPrompt('今天情绪很低落')" class="chip-soft text-xs">今天情绪很低落</button>
      <button onclick="sendAiPrompt('SP不理我怎么办')" class="chip-soft text-xs">SP不理我怎么办</button>
      <button onclick="sendAiPrompt('我想显化财富')" class="chip-soft text-xs">我想显化财富</button>
      <button onclick="sendAiPrompt('给我一句今天的肯定语')" class="chip-soft text-xs">今日肯定语</button>
      <button onclick="sendAiPrompt('我最近总是焦虑')" class="chip-soft text-xs">总是很焦虑</button>
    </div>
    <div class="flex gap-2">
      <input type="text" id="ai-input" class="dream-input" placeholder="和宇宙闺蜜说点什么..." onkeydown="if(event.key==='Enter')sendAiMessage()" style="flex:1">
      <button onclick="sendAiMessage()" class="btn-primary w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="padding:0">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- ========== 分享卡片模态框 ========== -->
<div id="share-card-modal" class="modal-backdrop" onclick="if(event.target===this)closeShareCard()">
  <div class="modal-content p-5" style="max-width:380px">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-medium">生成分享卡片</h3>
      <button onclick="closeShareCard()" class="w-8 h-8 rounded-full flex items-center justify-center" style="background:rgba(212,181,199,0.15)">✕</button>
    </div>
    <div id="share-card-preview" class="rounded-2xl p-6 mb-4 text-center" style="background:linear-gradient(135deg,#FFFEFF,#FAF5F7);border:1px solid rgba(255,255,255,0.8);box-shadow:0 8px 32px rgba(184,169,201,0.15)">
      <div class="text-xs mb-2" style="color:var(--text-mute)">✨ 星愿花园 · 星辰日记</div>
      <div id="share-card-date" class="text-xs mb-3" style="color:var(--text-mute)"></div>
      <div id="share-card-content" class="text-sm font-medium leading-relaxed mb-4" style="color:var(--theme-text);font-family:'ZCOOL XiaoWei',sans-serif"></div>
      <div class="flex items-center justify-center gap-2 text-xs" style="color:var(--text-mute)"><span>🏝️</span><span>星愿花园</span></div>
    </div>
    <div class="flex gap-2">
      <button onclick="downloadShareCard()" class="btn-primary flex-1 py-3 rounded-xl text-sm">保存图片</button>
      <button onclick="copyShareText()" class="btn-soft flex-1 py-3 rounded-xl text-sm">复制文字</button>
    </div>
  </div>
</div>

<!-- ========== 梦境工坊 ========== -->
<section id="page-dreams" class="page" style="padding-bottom:100px;">
  <div class="glass-header sticky top-0 z-40 px-5 py-4">
    <div class="flex items-center justify-between max-w-lg mx-auto">
      <button onclick="goHome()" class="soft-btn w-10 h-10 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,0.6)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="text-lg font-medium" style="color:var(--theme-text)">梦境工坊</h1>
      <div class="w-10"></div>
    </div>
  </div>
  <div class="max-w-lg mx-auto px-5 py-6">
    <div class="glass-card p-5 mb-6 text-center">
      <div class="text-3xl mb-2">🌙</div>
      <h2 class="text-xl font-medium mb-1" style="font-family:'ZCOOL XiaoWei',sans-serif">梦境是你的潜意识来信</h2>
      <p class="text-sm" style="color:var(--text-soft)">记录梦境，解读象征，发现宇宙给你的信号</p>
    </div>
    <div class="glass-card p-5 mb-6">
      <h3 class="font-medium mb-3">📝 记录昨晚的梦</h3>
      <textarea id="dream-content" class="dream-input mb-3" rows="4" placeholder="描述你的梦境...越详细越好，颜色、情绪、人物、地点..."></textarea>
      <div class="flex gap-2 mb-3">
        <select id="dream-mood" class="dream-input" style="flex:1">
          <option value="">梦境情绪</option><option value="愉悦">😊 愉悦</option><option value="焦虑">😰 焦虑</option><option value="恐惧">😨 恐惧</option><option value="平静">😌 平静</option><option value="兴奋">🤩 兴奋</option><option value="悲伤">😢 悲伤</option><option value="神秘">🔮 神秘</option>
        </select>
        <select id="dream-lucid" class="dream-input" style="flex:1">
          <option value="">是否清醒梦</option><option value="是">✨ 是</option><option value="否">💤 不是</option><option value="模糊">🌫️ 模糊</option>
        </select>
      </div>
      <button onclick="saveDream()" class="btn-primary w-full py-3 rounded-xl">记录梦境</button>
    </div>
    <div class="glass-card p-5 mb-6">
      <h3 class="font-medium mb-3">🔮 常见梦境象征</h3>
      <div id="dream-symbols" class="grid grid-cols-2 gap-2"></div>
    </div>
    <div class="glass-card p-5">
      <h3 class="font-medium mb-3">📚 我的梦境日记</h3>
      <div id="dream-history" class="space-y-3" style="max-height:400px;overflow-y:auto"></div>
    </div>
  </div>
</section>

<!-- ========== 星愿成真故事墙 ========== -->
<section id="page-stories" class="page" style="padding-bottom:100px;">
  <div class="glass-header sticky top-0 z-40 px-5 py-4">
    <div class="flex items-center justify-between max-w-lg mx-auto">
      <button onclick="goHome()" class="soft-btn w-10 h-10 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,0.6)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="text-lg font-medium" style="color:var(--theme-text)">显化故事墙</h1>
      <div class="w-10"></div>
    </div>
  </div>
  <div class="max-w-lg mx-auto px-5 py-6">
    <div class="glass-card p-5 mb-6 text-center">
      <div class="text-3xl mb-2">✨</div>
      <h2 class="text-xl font-medium mb-1" style="font-family:'ZCOOL XiaoWei',sans-serif">每一个显化都是奇迹</h2>
      <p class="text-sm" style="color:var(--text-soft)">阅读他人的故事，分享你的奇迹，能量会倍增</p>
    </div>
    <div class="glass-card p-5 mb-6">
      <h3 class="font-medium mb-3">📝 分享你的星愿奇迹</h3>
      <input type="text" id="story-title" class="dream-input mb-3" placeholder="给你的故事起个标题...">
      <select id="story-category" class="dream-input mb-3">
        <option value="">选择类别</option><option value="SP复合">💕 SP复合</option><option value="财富">💰 财富</option><option value="工作">💼 工作</option><option value="健康">🏥 健康</option><option value="自我成长">🌱 自我成长</option><option value="其他">🌟 其他</option>
      </select>
      <textarea id="story-content" class="dream-input mb-3" rows="4" placeholder="分享你的星愿故事...用了多久？做了什么？最后怎么实现的？"></textarea>
      <button onclick="submitStory()" class="btn-primary w-full py-3 rounded-xl">发布故事</button>
    </div>
    <div class="flex gap-2 mb-4 overflow-x-auto pb-1">
      <button class="chip-soft active" onclick="filterStories('all',this)">全部</button>
      <button class="chip-soft" onclick="filterStories('SP复合',this)">💕 SP复合</button>
      <button class="chip-soft" onclick="filterStories('财富',this)">💰 财富</button>
      <button class="chip-soft" onclick="filterStories('工作',this)">💼 工作</button>
      <button class="chip-soft" onclick="filterStories('自我成长',this)">🌱 成长</button>
    </div>
    <div id="stories-list" class="space-y-4"></div>
  </div>
</section>

<!-- ========== SATS深度冥想引导器 ========== -->
<section id="page-sats" class="page" style="padding-bottom:100px;">
  <div class="glass-header sticky top-0 z-40 px-5 py-4">
    <div class="flex items-center justify-between max-w-lg mx-auto">
      <button onclick="goHome()" class="soft-btn w-10 h-10 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,0.6)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="text-lg font-medium" style="color:var(--theme-text)">SATS冥想</h1>
      <div class="w-10"></div>
    </div>
  </div>
  <div class="max-w-lg mx-auto px-5 py-6">
    <div class="glass-card p-5 mb-6 text-center">
      <div class="text-3xl mb-2">🌙</div>
      <h2 class="text-xl font-medium mb-1" style="font-family:'ZCOOL XiaoWei',sans-serif">SATS · 状态像似睡眠</h2>
      <p class="text-sm" style="color:var(--text-soft)">临睡前的黄金15分钟，改写你的潜意识</p>
    </div>

    <!-- 睡梦显化引导 v5.4 -->
    <div id="sats-guide" class="glass-card p-5 mb-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-medium" style="color:var(--theme-text)">🧘 分步引导</h3>
        <div class="text-xs" style="color:var(--text-mute)">第 <span id="sats-step-num">1</span> / 5 步</div>
      </div>
      <div id="sats-step-content" class="mb-4">
        <div class="text-lg font-medium mb-2" style="color:var(--theme-text)">1. 放松身体</div>
        <div class="text-sm mb-3" style="color:var(--text-soft)">从头顶到脚底，逐一放松每一块肌肉。深呼吸三次，让身体沉入床中。</div>
        <div class="p-3 rounded-xl text-center" style="background:rgba(212,181,199,0.1)">
          <div class="text-2xl mb-1">🫁</div>
          <div class="text-xs" style="color:var(--text-mute)">吸气 4秒 → 屏息 4秒 → 呼气 6秒</div>
        </div>
      </div>
      <div class="flex gap-2 justify-between">
        <button onclick="prevSatsStep()" id="sats-prev-btn" class="btn-soft px-4 py-2 rounded-xl text-sm hidden">← 上一步</button>
        <button onclick="nextSatsStep()" id="sats-next-btn" class="btn-primary px-4 py-2 rounded-xl text-sm flex-1">下一步 →</button>
      </div>
    </div>

    <div class="glass-card p-5 mb-6">
      <h3 class="font-medium mb-3">🎬 选择你的场景</h3>
      <div id="sats-scenes" class="space-y-3"></div>
    </div>
    <div class="glass-card p-5 mb-6 text-center">
      <div class="text-5xl mb-4 font-medium" id="sats-timer-main" style="font-family:'ZCOOL XiaoWei',sans-serif;color:var(--theme-text)">15:00</div>
      <div class="flex gap-2 justify-center">
        <button onclick="startSatsTimer()" id="sats-btn-start" class="btn-primary px-6 py-2 rounded-xl">开始</button>
        <button onclick="pauseSatsTimer()" id="sats-btn-pause" class="btn-soft px-6 py-2 rounded-xl hidden">暂停</button>
        <button onclick="resetSatsTimer()" class="btn-soft px-6 py-2 rounded-xl">重置</button>
      </div>
      <p class="text-xs mt-4" style="color:var(--text-mute)">建议睡前进行，配合场景想象，直到自然入睡</p>
    </div>
    <div class="glass-card p-5">
      <h3 class="font-medium mb-3">📖 SATS 核心指引</h3>
      <div class="space-y-3 text-sm" style="color:var(--text-soft)">
        <p><span class="font-medium" style="color:var(--theme-text)">1. 放松身体</span> — 从头顶到脚底，逐一放松每一块肌肉</p>
        <p><span class="font-medium" style="color:var(--theme-text)">2. 想象场景</span> — 不是"看"画面，而是"进入"画面，成为其中的人</p>
        <p><span class="font-medium" style="color:var(--theme-text)">3. 感受情绪</span> — 最关键：让"已经拥有"的感觉充满全身</p>
        <p><span class="font-medium" style="color:var(--theme-text)">4. 循环重复</span> — 同一个场景在脑中反复播放，直到自然入睡</p>
        <p><span class="font-medium" style="color:var(--theme-text)">5. 信任过程</span> — 不需要知道"怎么做"，只需要知道"已经成"</p>
      </div>
    </div>
  </div>
</section>

<!-- ========== 数据备份与导出 ========== -->
<section id="page-backup" class="page" style="padding-bottom:100px;">
  <div class="glass-header sticky top-0 z-40 px-5 py-4">
    <div class="flex items-center justify-between max-w-lg mx-auto">
      <button onclick="goHome()" class="soft-btn w-10 h-10 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,0.6)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="text-lg font-medium" style="color:var(--theme-text)">数据备份</h1>
      <div class="w-10"></div>
    </div>
  </div>
  <div class="max-w-lg mx-auto px-5 py-6">
    <div class="glass-card p-5 mb-6 text-center">
      <div class="text-3xl mb-2">💾</div>
      <h2 class="text-xl font-medium mb-1" style="font-family:'ZCOOL XiaoWei',sans-serif">守护你的星愿数据</h2>
      <p class="text-sm" style="color:var(--text-soft)">所有记录都值得被安全保存</p>
    </div>
    <div class="glass-card p-5 mb-6">
      <h3 class="font-medium mb-3">📤 导出全部数据</h3>
      <p class="text-sm mb-4" style="color:var(--text-soft)">将你的星辰日记、情绪花园、打卡数据等导出为JSON文件，可跨设备迁移。</p>
      <div class="flex gap-2">
        <button onclick="exportAllData()" class="btn-primary flex-1 py-3 rounded-xl">导出备份文件</button>
        <button onclick="copyAllData()" class="btn-soft flex-1 py-3 rounded-xl">复制到剪贴板</button>
      </div>
    </div>
    <div class="glass-card p-5 mb-6">
      <h3 class="font-medium mb-3">📥 导入数据</h3>
      <p class="text-sm mb-4" style="color:var(--text-soft)">从备份文件恢复数据，或粘贴JSON文本。</p>
      <textarea id="import-data-text" class="dream-input mb-3" rows="4" placeholder="粘贴备份JSON内容..."></textarea>
      <button onclick="importAllData()" class="btn-primary w-full py-3 rounded-xl">导入数据</button>
    </div>
    <div class="glass-card p-5">
      <h3 class="font-medium mb-3">📊 数据概览</h3>
      <div id="data-overview" class="space-y-2"></div>
    </div>
  </div>
</section>


