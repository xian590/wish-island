<!-- ========== 限时优惠弹窗 ========== -->
<div id="limited-offer-modal" class="modal-backdrop" onclick="if(event.target===this)closeLimitedOffer()">
  <div class="modal-content p-6 text-center" style="max-width:340px">
    <div class="text-4xl mb-3">🎁</div>
    <h3 class="font-medium text-lg mb-1" style="font-family:'ZCOOL XiaoWei',sans-serif">限时特惠</h3>
    <p class="text-sm mb-3" style="color:var(--text-soft)">新用户专享，错过再等一年</p>
    <div class="p-4 rounded-2xl mb-4" style="background:linear-gradient(135deg,#FDE68A,#F59E0B)">
      <div class="text-white text-sm font-medium mb-1">宇宙会员首月</div>
      <div class="flex items-baseline justify-center gap-1">
        <span class="text-white text-lg">¥</span>
        <span class="text-white text-4xl font-bold">6</span>
        <span class="text-white text-sm opacity-70" style="text-decoration:line-through">¥18</span>
      </div>
      <div class="text-white text-xs mt-1 opacity-80">限时72小时 · 剩余 <span id="offer-timer">23:59:59</span></div>
    </div>
