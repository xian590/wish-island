      <div class="text-4xl mb-2">${m.icon}</div>
      <h3 class="font-display text-lg" style="color:var(--theme-text)">${m.name}</h3>
      <p class="text-xs" style="color:var(--theme-text); opacity:0.5">${m.summary}</p>
