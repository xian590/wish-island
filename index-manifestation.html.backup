      <h4 class="font-title text-sm mb-1" style="color:var(--theme-text)">${m.name}</h4>
      <p class="text-xs line-clamp-2" style="color:var(--theme-text); opacity:0.6">${m.summary}</p>
    </div>
  `).join('');
}

