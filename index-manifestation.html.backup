        <div class="text-center p-2 rounded-xl" style="background:rgba(255,255,255,0.5)" id="checkin-d-1"><div class="text-xs" style="color:var(--text-mute)">一</div><div class="text-lg">💎</div><div class="text-[10px]" style="color:var(--text-mute)">+5</div></div>
        <div class="text-center p-2 rounded-xl" style="background:rgba(255,255,255,0.5)" id="checkin-d-2"><div class="text-xs" style="color:var(--text-mute)">二</div><div class="text-lg">💎</div><div class="text-[10px]" style="color:var(--text-mute)">+5</div></div>
        <div class="text-center p-2 rounded-xl" style="background:rgba(255,255,255,0.5)" id="checkin-d-3"><div class="text-xs" style="color:var(--text-mute)">三</div><div class="text-lg">💎</div><div class="text-[10px]" style="color:var(--text-mute)">+5</div></div>
        <div class="text-center p-2 rounded-xl" style="background:rgba(255,255,255,0.5)" id="checkin-d-4"><div class="text-xs" style="color:var(--text-mute)">四</div><div class="text-lg">💎</div><div class="text-[10px]" style="color:var(--text-mute)">+5</div></div>
        <div class="text-center p-2 rounded-xl" style="background:rgba(255,255,255,0.5)" id="checkin-d-5"><div class="text-xs" style="color:var(--text-mute)">五</div><div class="text-lg">💎</div><div class="text-[10px]" style="color:var(--text-mute)">+5</div></div>
        <div class="text-center p-2 rounded-xl" style="background:rgba(255,255,255,0.5)" id="checkin-d-6"><div class="text-xs" style="color:var(--text-mute)">六</div><div class="text-lg">💎</div><div class="text-[10px]" style="color:var(--text-mute)">+10</div></div>
        <div class="text-center p-2 rounded-xl" style="background:rgba(255,255,255,0.5)" id="checkin-d-7"><div class="text-xs" style="color:var(--text-mute)">日</div><div class="text-lg">🎁</div><div class="text-[10px]" style="color:var(--text-mute)">+20</div></div>
