      <div class="text-2xl mb-2">🧘</div>
      <div class="text-sm font-medium" style="color:var(--theme-text)">对着梦想画册做 SATS</div>
      <div class="text-xs mt-1" style="color:var(--text-mute)">闭上眼，想象这些画面已经是你的现实</div>
    </div>
  </div>
</section>

<!-- ========== 数据 QR 码同步 ========== -->
<section id="page-qr-sync" class="page" style="padding-bottom:100px;">
  <div class="glass-header sticky top-0 z-40 px-5 py-4">
    <div class="flex items-center justify-between max-w-lg mx-auto">
      <button onclick="goBack()" class="soft-btn w-10 h-10 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,0.6)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="text-lg font-medium" style="color:var(--theme-text)">数据同步</h1>
      <div class="w-10"></div>
    </div>
  </div>
  <div class="max-w-lg mx-auto px-5 py-6">
    <div class="glass-card p-5 mb-6 text-center">
      <div class="text-3xl mb-2">📲</div>
      <h2 class="text-xl font-medium mb-1" style="font-family:'ZCOOL XiaoWei',sans-serif">跨设备数据迁移</h2>
      <p class="text-sm" style="color:var(--text-soft)">换手机？扫码一键迁移全部数据</p>
    </div>

    <div class="grid grid-cols-2 gap-3 mb-6">
      <div class="glass-card p-4 text-center cursor-pointer card-hover" onclick="generateDataQR()">
        <div class="text-2xl mb-2">📤</div>
        <div class="text-sm font-medium" style="color:var(--theme-text)">生成同步码</div>
        <div class="text-xs mt-1" style="color:var(--text-mute)">导出本机数据</div>
      </div>
      <div class="glass-card p-4 text-center cursor-pointer card-hover" onclick="showImportInput()">
        <div class="text-2xl mb-2">📥</div>
        <div class="text-sm font-medium" style="color:var(--theme-text)">扫码导入</div>
        <div class="text-xs mt-1" style="color:var(--text-mute)">从其他设备导入</div>
      </div>
    </div>

    <div id="qr-export-area" class="hidden">
      <div class="glass-card p-5 mb-4">
        <div class="text-sm font-medium mb-3" style="color:var(--theme-text)">📦 选择要导出的数据</div>
        <div id="export-options" class="space-y-2 mb-4"></div>
        <div class="flex gap-2 mb-4">
          <button onclick="selectAllExport(true)" class="btn-soft px-3 py-1.5 rounded-lg text-xs">全选</button>
          <button onclick="selectAllExport(false)" class="btn-soft px-3 py-1.5 rounded-lg text-xs">取消全选</button>
        </div>
        <button onclick="exportSelectedData()" class="btn-primary w-full py-3 rounded-xl text-sm">生成同步码</button>
        <div id="qr-code-display" class="mt-4 mb-3" style="display:flex;justify-content:center"></div>
        <div class="text-sm mb-2 text-center" style="color:var(--theme-text)">用另一台设备扫描此码</div>
        <div class="text-xs text-center" style="color:var(--text-mute)">数据已压缩为文本，有效期10分钟</div>
        <button onclick="copyDataText()" class="btn-soft mt-3 w-full py-2 rounded-xl text-sm">复制文本备用</button>
      </div>
    </div>

    <div id="qr-import-area" class="hidden">
      <div class="glass-card p-5 mb-4">
        <div class="text-sm font-medium mb-2" style="color:var(--theme-text)">📥 粘贴同步文本</div>
        <textarea id="qr-import-text" class="dream-input mb-3" rows="4" placeholder="粘贴从另一台设备复制的同步文本..."></textarea>
        <button onclick="importFromQRText()" class="btn-primary w-full py-3 rounded-xl text-sm mb-3">解析数据</button>
        <div id="import-preview" class="hidden p-3 rounded-xl mb-3" style="background:rgba(255,255,255,0.5);max-height:200px;overflow-y:auto"></div>
        <button id="import-confirm-btn" onclick="confirmImport()" class="btn-primary w-full py-3 rounded-xl text-sm hidden">✅ 确认导入</button>
      </div>
    </div>
  </div>
</section>

