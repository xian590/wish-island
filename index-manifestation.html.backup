          </div>
          <div class="text-xs px-2 py-1 rounded-full" style="background:rgba(212,181,199,0.15);color:var(--text-soft)" id="task-share">进行中</div>
        </div>
        <div class="flex items-center justify-between p-3 rounded-xl" style="background:rgba(255,255,255,0.5)">
          <div class="flex items-center gap-3">
            <div class="text-xl">📖</div>
            <div><div class="text-sm font-medium" style="color:var(--theme-text)">阅读书籍</div><div class="text-xs" style="color:var(--text-mute)">+10 星光水晶/本</div></div>
          </div>
          <div class="text-xs px-2 py-1 rounded-full" style="background:rgba(212,181,199,0.15);color:var(--text-soft)" id="task-book">进行中</div>
        </div>
        <div class="flex items-center justify-between p-3 rounded-xl" style="background:rgba(255,255,255,0.5)">
          <div class="flex items-center gap-3">
            <div class="text-xl">🤝</div>
            <div><div class="text-sm font-medium" style="color:var(--theme-text)">邀请好友</div><div class="text-xs" style="color:var(--text-mute)">双方各 +30 星光水晶</div></div>
